ems-center gap-2\" data-kid=\"3-2-7-1-2-1-2-4-6-1\" data-name=\"health container\">\n<i class=\"ti ti-heart-filled text-[#059669]\" data-kid=\"3-2-7-1-2-1-2-4-6-1-1\" data-name=\"heart icon\"></i>\n<span class=\"text-xs font-bold tabular-nums\" data-kid=\"3-2-7-1-2-1-2-4-6-1-2\" data-name=\"health percentage\">100%</span>\n</div>\n</td>\n</tr>\n\n<tr class=\"hover:bg-[#F8FAFC] transition-colors cursor-pointer group\" data-kid=\"3-2-7-1-2-1-2-5\" data-name=\"table row 5\">\n<td class=\"px-6 py-4\" data-kid=\"3-2-7-1-2-1-2-5-1\" data-name=\"vehicle cell\">\n<div class=\"text-sm font-bold text-[#0A0F1E]\" data-kid=\"3-2-7-1-2-1-2-5-1-1\" data-name=\"vehicle name\">Volvo VNL 860</div>\n<div class=\"text-[10px] font-medium text-[#94A3B8] tracking-wider\" data-kid=\"3-2-7-1-2-1-2-5-1-2\" data-name=\"vehicle model\">Semi-Truck • #TRK-704</div>\n</td>\n<td class=\"px-6 py-4\" data-kid=\"3-2-7-1-2-1-2-5-2\" data-name=\"driver cell\">\n<div class=\"flex items-center gap-3\" data-kid=\"3-2-7-1-2-1-2-5-2-1\" data-name=\"driver info container\">\n<div class=\"w-8 h-8 rounded-full bg-[#FEF2F2] flex items-center justify-center text-[10px] font-bold text-[#DC2626] border border-[#DC2626]/10\" data-kid=\"3-2-7-1-2-1-2-5-2-1-1\" data-name=\"driver initials\">MM</div>\n<span class=\"text-sm font-semibold\" data-kid=\"3-2-7-1-2-1-2-5-2-1-2\" data-name=\"driver name\">Michael Miller</span>\n</div>\n</td>\n<td class=\"px-6 py-4\" data-kid=\"3-2-7-1-2-1-2-5-3\" data-name=\"status cell\">\n<div class=\"status-pill bg-[#FEF2F2] text-[#DC2626]\" data-kid=\"3-2-7-1-2-1-2-5-3-1\" data-name=\"status pill\">\n<div class=\"status-dot bg-[#DC2626]\" data-kid=\"3-2-7-1-2-1-2-5-3-1-1\" data-name=\"status dot\"></div>\n                    In Shop\n                  </div>\n</td>\n<td class=\"px-6 py-4 text-sm text-[#94A3B8]\" data-kid=\"3-2-7-1-2-1-2-5-4\" data-name=\"cargo cell\">N/A (Shop Rep...)</td>\n<td class=\"px-6 py-4 text-sm font-bold text-[#DC2626]\" data-kid=\"3-2-7-1-2-1-2-5-5\" data-name=\"eta cell\">In Service</td>\n<td class=\"px-6 py-4\" data-kid=\"3-2-7-1-2-1-2-5-6\" data-name=\"health cell\">\n<div class=\"flex items-center gap-2\" data-kid=\"3-2-7-1-2-1-2-5-6-1\" data-name=\"health container\">\n<i class=\"ti ti-heart-filled text-[#DC2626]\" data-kid=\"3-2-7-1-2-1-2-5-6-1-1\" data-name=\"heart icon\"></i>\n<span class=\"text-xs font-bold tabular-nums text-[#DC2626]\" data-kid=\"3-2-7-1-2-1-2-5-6-1-2\" data-name=\"health percentage\">54%</span>\n</div>\n</td>\n</tr>\n</tbody>\n</table>\n</div>\n</div>\n\n<div class=\"bg-white rounded-[18px] border border-[#E2E8F0] p-6 card-shadow flex flex-col\" data-kid=\"3-2-7-2\" data-name=\"fleet health diagnostics panel\">\n<div class=\"flex items-center gap-3 mb-8\" data-kid=\"3-2-7-2-1\" data-name=\"header area\">\n<div class=\"w-10 h-10 rounded-xl bg-[#F8FAFC] flex items-center justify-center border border-[#E2E8F0]\" data-kid=\"3-2-7-2-1-1\" data-name=\"icon box\">\n<i class=\"ti ti-heartbeat text-[#2563EB]\" data-kid=\"3-2-7-2-1-1-1\" data-name=\"heartbeat icon\"></i>\n</div>\n<div data-kid=\"3-2-7-2-1-2\" data-name=\"title text\">\n<h3 class=\"text-lg font-bold text-[#0A0F1E]\" data-kid=\"3-2-7-2-1-2-1\" data-name=\"title\">Fleet Health Panel</h3>\n<p class=\"text-[11px] font-medium text-[#94A3B8] uppercase tracking-wider\" data-kid=\"3-2-7-2-1-2-2\" data-name=\"subtitle\">Telemetry and compliance diagnostics</p>\n</div>\n</div>\n<div class=\"space-y-4 flex-1\" data-kid=\"3-2-7-2-2\" data-name=\"diagnostics items\">\n\n<div class=\"p-4 border border-[#F1F5F9] rounded-2xl hover:border-[#2563EB]/30 hover:bg-[#F8FAFC] transition-all\" data-kid=\"3-2-7-2-2-1\" data-name=\"maintenance card\">\n<div class=\"flex items-center justify-between mb-3\" data-kid=\"3-2-7-2-2-1-1\" data-name=\"card header\">\n<div class=\"flex items-center gap-2 text-xs font-bold\" data-kid=\"3-2-7-2-2-1-1-1\" data-name=\"title\">\n<i class=\"ti ti-wrench text-[#2563EB]\" data-kid=\"3-2-7-2-2-1-1-1-1\" data-name=\"wrench icon\"></i>\n                Scheduled Maintenance\n              </div>\n<span class=\"text-[10px] font-bold text-[#475569] tabular-nums\" data-kid=\"3-2-7-2-2-1-1-2\" data-name=\"progress status text\">12 / 17 Serviced</span>\n</div>\n<div class=\"w-full h-1.5 bg-[#F1F5F9] rounded-full overflow-hidden mb-2\" data-kid=\"3-2-7-2-2-1-2\" data-name=\"progress bar track\">\n<div class=\"h-full bg-[#2563EB] w-[70.5%] rounded-full\" data-kid=\"3-2-7-2-2-1-2-1\" data-name=\"progress bar fill\"></div>\n</div>\n<div class=\"flex items-center justify-between\" data-kid=\"3-2-7-2-2-1-3\" data-name=\"footer text\">\n<span class=\"text-[10px] text-[#94A3B8]\" data-kid=\"3-2-7-2-2-1-3-1\" data-name=\"progress percentage\">Progress: <span class=\"font-bold\" data-kid=\"3-2-7-2-2-1-3-1-1\" data-name=\"percentage value\">70.5%</span> completed</span>\n<a class=\"text-[10px] font-bold text-[#2563EB] hover:underline\" data-kid=\"3-2-7-2-2-1-3-2\" data-name=\"link\" href=\"#\">View Schedule ›</a>\n</div>\n</div>\n\n<div class=\"p-4 border border-[#F1F5F9] rounded-2xl hover:border-[#2563EB]/30 hover:bg-[#F8FAFC] transition-all\" data-kid=\"3-2-7-2-2-2\" data-name=\"license alert card\">\n<div class=\"flex items-center gap-2 text-xs font-bold mb-4\" data-kid=\"3-2-7-2-2-2-1\" data-name=\"title\">\n<i class=\"ti ti-file-text text-[#2563EB]\" data-kid=\"3-2-7-2-2-2-1-1\" data-name=\"file icon\"></i>\n              License Expiry Alerts\n            </div>\n<div class=\"space-y-4\" data-kid=\"3-2-7-2-2-2-2\" data-name=\"alert list\">\n<div class=\"flex items-start justify-between\" data-kid=\"3-2-7-2-2-2-2-1\" data-name=\"alert item 1\">\n<div data-kid=\"3-2-7-2-2-2-2-1-1\" data-name=\"info\">\n<div class=\"text-[11px] font-bold text-[#0A0F1E]\" data-kid=\"3-2-7-2-2-2-2-1-1-1\" data-name=\"title\">Class A CDL (Sarah Davis)</div>\n<div class=\"text-[10px] text-[#94A3B8]\" data-kid=\"3-2-7-2-2-2-2-1-1-2\" data-name=\"subtitle\">Compliance renewal required</div>\n</div>\n<div class=\"px-2 py-0.5 bg-[#FEF2F2] text-[#DC2626] text-[9px] font-black rounded uppercase tracking-wider border border-[#DC2626]/10\" data-kid=\"3-2-7-2-2-2-2-1-2\" data-name=\"due date badge\">⚠ 3 Days Left</div>\n</div>\n<div class=\"flex items-start justify-between\" data-kid=\"3-2-7-2-2-2-2-2\" data-name=\"alert item 2\">\n<div data-kid=\"3-2-7-2-2-2-2-2-1\" data-name=\"info\">\n<div class=\"text-[11px] font-bold text-[#0A0F1E]\" data-kid=\"3-2-7-2-2-2-2-2-1-1\" data-name=\"title\">IFTA Permit (Asset #TRK-892)</div>\n<div class=\"text-[10px] text-[#94A3B8]\" data-kid=\"3-2-7-2-2-2-2-2-1-2\" data-name=\"subtitle\">Quarterly taxation registry</div>\n</div>\n<div class=\"px-2 py-0.5 bg-[#FFFBEB] text-[#D97706] text-[9px] font-black rounded uppercase tracking-wider border border-[#D97706]/10\" data-kid=\"3-2-7-2-2-2-2-2-2\" data-name=\"due date badge\">14 Days Left</div>\n</div>\n</div>\n</div>\n\n<div class=\"p-4 border border-[#F1F5F9] rounded-2xl hover:border-[#2563EB]/30 hover:bg-[#F8FAFC] transition-all\" data-kid=\"3-2-7-2-2-3\" data-name=\"fuel efficiency card\">\n<div class=\"flex items-center justify-between mb-3\" data-kid=\"3-2-7-2-2-3-1\" data-name=\"header\">\n<div class=\"flex items-center gap-2 text-xs font-bold\" data-kid=\"3-2-7-2-2-3-1-1\" data-name=\"title\">\n<i class=\"ti ti-gas-station text-[#2563EB]\" data-kid=\"3-2-7-2-2-3-1-1-1\" data-name=\"gas station icon\"></i>\n                Fuel Consumption Index\n              </div>\n</div>\n<div class=\"flex items-end justify-between mb-3\" data-kid=\"3-2-7-2-2-3-2\" data-name=\"index display\">\n<div class=\"text-2xl font-black text-[#0A0F1E] tabular-nums\" data-kid=\"3-2-7-2-2-3-2-1\" data-name=\"mpg value\">6.8 <span class=\"text-xs font-bold text-[#94A3B8]\" data-kid=\"3-2-7-2-2-3-2-1-1\" data-name=\"label\">MPG</span></div>\n<span class=\"text-[10px] font-bold text-[#94A3B8]\" data-kid=\"3-2-7-2-2-3-2-2\" data-name=\"target label\">Fleet Target: 7.5 MPG</span>\n</div>\n<div class=\"w-full h-1.5 bg-[#F1F5F9] rounded-full overflow-hidden mb-2\" data-kid=\"3-2-7-2-2-3-3\" data-name=\"progress bar track\">\n<div class=\"h-full bg-[#2563EB] w-[91%] rounded-full\" data-kid=\"3-2-7-2-2-3-3-1\" data-name=\"progress bar fill\"></div>\n</div>\n<span class=\"text-[10px] text-[#94A3B8]\" data-kid=\"3-2-7-2-2-3-4\" data-name=\"efficiency status text\">Average efficiency: <span class=\"font-bold text-[#DC2626]\" data-kid=\"3-2-7-2-2-3-4-1\" data-name=\"percentage discrepancy\">9.3% below</span> optimization target</span>\n</div>\n\n<div class=\"p-4 border border-[#F1F5F9] rounded-2xl hover:border-[#2563EB]/30 hover:bg-[#F8FAFC] transition-all\" data-kid=\"3-2-7-2-2-4\" data-name=\"cost assets card\">\n<div class=\"flex items-center gap-2 text-xs font-bold mb-4\" data-kid=\"3-2-7-2-2-4-1\" data-name=\"header\">\n<i class=\"ti ti-currency-dollar text-[#2563EB]\" data-kid=\"3-2-7-2-2-4-1-1\" data-name=\"dollar icon\"></i>\n              High Cost Assets (MTD)\n            </div>\n<div class=\"space-y-3\" data-kid=\"3-2-7-2-2-4-2\" data-name=\"list\">\n<div class=\"flex items-center justify-between\" data-kid=\"3-2-7-2-2-4-2-1\" data-name=\"item 1\">\n<span class=\"text-[11px] font-bold text-[#475569]\" data-kid=\"3-2-7-2-2-4-2-1-1\" data-name=\"asset name\">Volvo VNL (#TRK-892)</span>\n<span class=\"text-[11px] font-black text-[#DC2626] tabular-nums\" data-kid=\"3-2-7-2-2-4-2-1-2\" data-name=\"asset cost\">$2,410.50</span>\n</div>\n<div class=\"flex items-center justify-between\" data-kid=\"3-2-7-2-2-4-2-2\" data-name=\"item 2\">\n<span class=\"text-[11px] font-bold text-[#475569]\" data-kid=\"3-2-7-2-2-4-2-2-1\" data-name=\"asset name\">Peterbilt 579 (#TRK-544)</span>\n<span class=\"text-[11px] font-black text-[#0A0F1E] tabular-nums\" data-kid=\"3-2-7-2-2-4-2-2-2\" data-name=\"asset cost\">$1,850.00</span>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n\n<button class=\"fixed bottom-8 right-8 w-14 h-14 bg-[#2563EB] text-white rounded-full flex items-center justify-center shadow-2xl hover:scale-110 active:scale-95 transition-all z-[100] group\" data-kid=\"4\" data-name=\"ai assistant button\">\n<i class=\"ti ti-robot text-2xl\" data-kid=\"4-1\" data-name=\"robot icon\"></i>\n<div class=\"absolute right-full mr-4 px-4 py-2 bg-[#0A0F1E] text-white text-xs font-bold rounded-xl opacity-0 translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-all pointer-events-none whitespace-nowrap\" data-kid=\"4-2\" data-name=\"ai assistant greeting text\">\n    How can I help you today?\n  </div>\n</button>\n<script data-kid=\"16\">\n  // Helper to generate sparkline data\n  const genSpark = (trend) => {\n    return {\n      labels: Array(10).fill(''),\n      datasets: [{\n        data: Array.from({length: 10}, () => Math.floor(Math.random() * 50) + (trend === 'up' ? 50 : 0)),\n        borderColor: trend === 'up' ? '#059669' : trend === 'down' ? '#DC2626' : '#2563EB',\n        borderWidth: 2,\n        fill: false,\n        tension: 0.4,\n        pointRadius: 0\n      }]\n    };\n  };\n\n  const sparkOptions = {\n    responsive: true,\n    maintainAspectRatio: false,\n    plugins: { legend: { display: false }, tooltip: { enabled: false } },\n    scales: { x: { display: false }, y: { display: false } }\n  };\n\n  window.onload = () => {\n    // Sparklines\n    new Chart(document.getElementById('sparkline-1'), { type: 'line', data: genSpark('up'), options: sparkOptions });\n    new Chart(document.getElementById('sparkline-2'), { type: 'line', data: genSpark('up'), options: sparkOptions });\n    new Chart(document.getElementById('sparkline-3'), { type: 'line', data: genSpark('down'), options: sparkOptions });\n    new Chart(document.getElementById('sparkline-4'), { type: 'line', data: genSpark('up'), options: sparkOptions });\n    new Chart(document.getElementById('sparkline-5'), { type: 'line', data: genSpark('neutral'), options: sparkOptions });\n    new Chart(document.getElementById('sparkline-6'), { type: 'line', data: genSpark('up'), options: sparkOptions });\n\n    // Utilization Trend Chart\n    const ctxTrend = document.getElementById('utilizationTrendChart').getContext('2d');\n    const gradient = ctxTrend.createLinearGradient(0, 0, 0, 300);\n    gradient.addColorStop(0, 'rgba(37, 99, 235, 0.1)');\n    gradient.addColorStop(1, 'rgba(37, 99, 235, 0)');\n\n    new Chart(ctxTrend, {\n      type: 'line',\n      data: {\n        labels: ['Apr', '', 'May', '', 'Jun', ''],\n        datasets: [{\n          label: 'Utilization',\n          data: [76, 78, 82, 80, 84, 86],\n          borderColor: '#2563EB',\n          borderWidth: 3,\n          fill: true,\n          backgroundColor: gradient,\n          tension: 0.4,\n          pointBackgroundColor: '#2563EB',\n          pointBorderColor: '#fff',\n          pointBorderWidth: 2,\n          pointRadius: 4,\n          pointHoverRadius: 6\n        }]\n      },\n      options: {\n        responsive: true,\n        maintainAspectRatio: false,\n        plugins: { legend: { display: false } },\n        scales: {\n          y: {\n            min: 50,\n            max: 100,\n            grid: { color: '#F1F5F9', borderDash: [5, 5] },\n            ticks: { stepSize: 10, font: { family: 'Outfit', weight: 'bold' }, color: '#94A3B8' }\n          },\n          x: {\n            grid: { display: false },\n            ticks: { font: { family: 'Outfit', weight: 'bold' }, color: '#94A3B8' }\n          }\n        }\n      }\n    });\n\n    // Vehicle Status Donut\n    new Chart(document.getElementById('vehicleStatusDonut'), {\n      type: 'doughnut',\n      data: {\n        datasets: [{\n          data: [55, 30, 12, 3],\n          backgroundColor: ['#059669', '#2563EB', '#DC2626', '#94A3B8'],\n          borderWidth: 0,\n          hoverOffset: 4\n        }]\n      },\n      options: {\n        cutout: '82%',\n        responsive: true,\n        maintainAspectRatio: false,\n        plugins: { legend: { display: false } }\n      }\n    });\n  };\n</script>",
