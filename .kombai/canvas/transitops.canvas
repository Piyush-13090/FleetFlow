      "html": "<link data-kid=\"1\" data-name=\"Google Fonts stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&amp;display=swap\" rel=\"stylesheet\">\n<link data-kid=\"2\" data-name=\"Tabler Icons stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" rel=\"stylesheet\">\n<style data-kid=\"0\">\n  @import \"tailwindcss\";\n\n  @theme {\n    --color-primary: #2563EB;\n    --color-accent-blue: #3B82F6;\n    --color-light-blue: #DBEAFE;\n    --color-bg-main: #F8FAFC;\n    --color-card: #FFFFFF;\n    --color-text-dark: #0F172A;\n    --color-border-gray: #E2E8F0;\n    --color-success-green: #22C55E;\n    --color-danger-red: #EF4444;\n\n    --font-sans: 'Outfit', system-ui, -apple-system, sans-serif;\n\n    --animate-shake: shake 0.4s ease-in-out;\n    --animate-float: float 6s ease-in-out infinite;\n\n    @keyframes shake {\n      0%, 100% { transform: translateX(0); }\n      10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }\n      20%, 40%, 60%, 80% { transform: translateX(5px); }\n    }\n    @keyframes float {\n      0%, 100% { transform: translateY(0px); }\n      50% { transform: translateY(-8px); }\n    }\n  }\n\n  @layer base {\n    body {\n      font-family: var(--font-sans);\n      background-color: var(--color-bg-main);\n      color: var(--color-text-dark);\n      margin: 0;\n      padding: 0;\n    }\n  }\n\n  @layer components {\n    .glass-panel {\n      background: rgba(255, 255, 255, 0.75);\n      backdrop-filter: blur(16px) saturate(120%);\n      -webkit-backdrop-filter: blur(16px) saturate(120%);\n      border: 1px solid rgba(255, 255, 255, 0.4);\n    }\n\n    .ripple-btn {\n      position: relative;\n      overflow: hidden;\n      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n    }\n    \n    .ripple-btn:active {\n      transform: scale(0.95);\n    }\n  }\n\n  /* Custom styling for the safety score ring colorization */\n  .safety-ring {\n    filter: invert(34%) sepia(87%) saturate(1966%) hue-rotate(212deg) brightness(97%) contrast(92%);\n  }\n</style>\n<div class=\"flex flex-col w-full min-h-[1600px] overflow-x-hidden\" data-kid=\"3\" data-name=\"main layout container\">\n\n<section class=\"relative w-full h-[800px] overflow-hidden\" data-kid=\"3-1\" data-name=\"geographic canvas hero section\">\n\n<img alt=\"Aerial view of landscape, photo by iuliu illes on Unsplash\" class=\"absolute inset-0 w-full h-full object-cover opacity-60 mix-blend-multiply grayscale-[20%]\" data-kid=\"3-1-1\" data-name=\"aerial landscape satellite image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1772655151089-ffc26fe82b65?auto=format&amp;w=1600&amp;q=80&amp;fit=crop\">\n\n<div class=\"absolute inset-0 bg-radial-[circle_at_50%_50%] from-transparent to-[var(--color-bg-main)] opacity-40\" data-kid=\"3-1-2\" data-name=\"hero radial background pulse effect\"></div>\n\n<div class=\"absolute top-16 right-16 flex flex-col gap-6 w-[360px]\" data-kid=\"3-1-3\" data-name=\"dashboard islands container\">\n<div class=\"glass-panel p-8 rounded-[32px] shadow-2xl space-y-4\" data-kid=\"3-1-3-1\" data-name=\"fleet utilization card\">\n<div class=\"flex justify-between items-start\" data-kid=\"3-1-3-1-1\" data-name=\"fleet utilization header area\">\n<span class=\"text-sm font-semibold tracking-wider text-slate-500 uppercase\" data-kid=\"3-1-3-1-1-1\" data-name=\"fleet utilization title label\">Fleet Utilization</span>\n<div class=\"relative flex items-center justify-center\" data-kid=\"3-1-3-1-1-2\" data-name=\"pulse activity icon container\">\n<i class=\"ti ti-activity text-2xl text-[var(--color-primary)] animate-pulse\" data-kid=\"3-1-3-1-1-2-1\" data-name=\"activity activity status icon\"></i>\n<span class=\"absolute w-full h-full rounded-full bg-[var(--color-primary)] opacity-20 animate-ping\" data-kid=\"3-1-3-1-1-2-2\" data-name=\"pulsing activity status ring\"></span>\n</div>\n</div>\n<div class=\"flex items-baseline gap-2\" data-kid=\"3-1-3-1-2\" data-name=\"utilization percentage readout\">\n<h2 class=\"text-7xl font-extrabold tracking-tighter text-[var(--color-text-dark)]\" data-kid=\"3-1-3-1-2-1\" data-name=\"utilization percentage value\">94.2</h2>\n<span class=\"text-3xl font-bold text-[var(--color-primary)]\" data-kid=\"3-1-3-1-2-2\" data-name=\"utilization percentage symbol\">%</span>\n</div>\n<div class=\"flex gap-1\" data-kid=\"3-1-3-1-3\" data-name=\"utilization progress bar container\">\n<div class=\"h-1.5 w-full bg-slate-200 rounded-full overflow-hidden\" data-kid=\"3-1-3-1-3-1\" data-name=\"utilization bar track\">\n<div class=\"h-full w-[94.2%] bg-[var(--color-primary)]\" data-kid=\"3-1-3-1-3-1-1\" data-name=\"utilization progress fill\"></div>\n</div>\n</div>\n</div>\n<div class=\"glass-panel p-6 rounded-[24px] shadow-xl flex items-center justify-between\" data-kid=\"3-1-3-2\" data-name=\"active trips summary card\">\n<div data-kid=\"3-1-3-2-1\" data-name=\"active trips count container\">\n<span class=\"text-xs font-bold tracking-widest text-slate-400 uppercase\" data-kid=\"3-1-3-2-1-1\" data-name=\"active trips label\">Active Trips</span>\n<p class=\"text-3xl font-extrabold text-[var(--color-text-dark)] mt-1\" data-kid=\"3-1-3-2-1-2\" data-name=\"active trips count value\">1,204</p>\n</div>\n<div class=\"p-3 bg-[var(--color-light-blue)] rounded-xl\" data-kid=\"3-1-3-2-2\" data-name=\"active trips icon container\">\n<i class=\"ti ti-truck-delivery text-[var(--color-primary)] text-2xl\" data-kid=\"3-1-3-2-2-1\" data-name=\"delivery truck icon\"></i>\n</div>\n</div>\n</div>\n\n<div class=\"absolute top-1/2 left-1/3 group\" data-kid=\"3-1-4\" data-name=\"simulated map marker container\">\n<div class=\"relative\" data-kid=\"3-1-4-1\" data-name=\"map marker base\">\n<div class=\"w-4 h-4 bg-[var(--color-primary)] rounded-full border-2 border-white shadow-lg animate-bounce\" data-kid=\"3-1-4-1-1\" data-name=\"map marker bouncing dot\"></div>\n<div class=\"absolute -top-12 -left-12 glass-panel px-3 py-1.5 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap text-xs font-bold\" data-kid=\"3-1-4-1-2\" data-name=\"map marker hover tooltip\">\n          Unit 77-A (Moving)\n        </div>\n</div>\n</div>\n</section>\n\n<div class=\"relative z-30 w-full flex justify-center -mt-12 px-12\" data-kid=\"3-2\" data-name=\"quick dispatch waistband container\">\n<div class=\"w-full max-w-6xl glass-panel rounded-full p-4 flex justify-between items-center shadow-2xl border-white/50\" data-kid=\"3-2-1\" data-name=\"quick dispatch control bar\">\n<div class=\"flex items-center gap-4 pl-6 border-r border-slate-200 pr-8\" data-kid=\"3-2-1-1\" data-name=\"fleet commander logo area\">\n<div class=\"w-10 h-10 bg-[var(--color-primary)] rounded-full flex items-center justify-center\" data-kid=\"3-2-1-1-1\" data-name=\"fleet commander icon container\">\n<i class=\"ti ti-route text-white text-xl\" data-kid=\"3-2-1-1-1-1\" data-name=\"route navigation icon\"></i>\n</div>\n<div data-kid=\"3-2-1-1-2\" data-name=\"fleet commander text container\">\n<h3 class=\"text-sm font-extrabold tracking-tight\" data-kid=\"3-2-1-1-2-1\" data-name=\"fleet commander title\">Fleet Commander</h3>\n<p class=\"text-[10px] text-slate-500 font-bold uppercase tracking-widest\" data-kid=\"3-2-1-1-2-2\" data-name=\"fleet commander subtitle\">Real-Time Control</p>\n</div>\n</div>\n<div class=\"flex gap-4 flex-1 justify-center px-8\" data-kid=\"3-2-1-2\" data-name=\"dispatch action buttons container\">\n<button class=\"ripple-btn glass-panel px-6 py-3 rounded-full flex items-center gap-3 hover:bg-[var(--color-primary)] hover:text-white group\" data-kid=\"3-2-1-2-1\" data-name=\"dispatch unit button\">\n<i class=\"ti ti-send text-lg text-[var(--color-primary)] group-hover:text-white\" data-kid=\"3-2-1-2-1-1\" data-name=\"dispatch unit icon\"></i>\n<span class=\"text-sm font-bold\" data-kid=\"3-2-1-2-1-2\" data-name=\"dispatch unit label\">Dispatch Unit</span>\n</button>\n<button class=\"ripple-btn glass-panel px-6 py-3 rounded-full flex items-center gap-3 hover:bg-[var(--color-primary)] hover:text-white group\" data-kid=\"3-2-1-2-2\" data-name=\"reroute active button\">\n<i class=\"ti ti-git-merge text-lg text-[var(--color-primary)] group-hover:text-white\" data-kid=\"3-2-1-2-2-1\" data-name=\"reroute icon\"></i>\n<span class=\"text-sm font-bold\" data-kid=\"3-2-1-2-2-2\" data-name=\"reroute label\">Reroute Active</span>\n</button>\n<button class=\"ripple-btn glass-panel px-6 py-3 rounded-full flex items-center gap-3 hover:bg-[var(--color-primary)] hover:text-white group\" data-kid=\"3-2-1-2-3\" data-name=\"broadcast alert button\">\n<i class=\"ti ti-radio text-lg text-[var(--color-primary)] group-hover:text-white\" data-kid=\"3-2-1-2-3-1\" data-name=\"broadcast icon\"></i>\n<span class=\"text-sm font-bold\" data-kid=\"3-2-1-2-3-2\" data-name=\"broadcast label\">Broadcast Alert</span>\n</button>\n<button class=\"ripple-btn glass-panel px-6 py-3 rounded-full flex items-center gap-3 hover:bg-[var(--color-primary)] hover:text-white group\" data-kid=\"3-2-1-2-4\" data-name=\"maintenance log button\">\n<i class=\"ti ti-wrench text-lg text-[var(--color-primary)] group-hover:text-white\" data-kid=\"3-2-1-2-4-1\" data-name=\"maintenance icon\"></i>\n<span class=\"text-sm font-bold\" data-kid=\"3-2-1-2-4-2\" data-name=\"maintenance label\">Maintenance Log</span>\n</button>\n</div>\n<div class=\"flex items-center gap-3 pr-6 pl-8 border-l border-slate-200\" data-kid=\"3-2-1-3\" data-name=\"user profile navigation area\">\n<div class=\"relative\" data-kid=\"3-2-1-3-1\" data-name=\"search trigger container\">\n<i class=\"ti ti-search text-slate-400 text-xl\" data-kid=\"3-2-1-3-1-1\" data-name=\"search icon\"></i>\n</div>\n<div class=\"w-10 h-10 bg-slate-100 rounded-full border-2 border-white overflow-hidden shadow-inner\" data-kid=\"3-2-1-3-2\" data-name=\"profile photo container\">\n<img alt=\"Profile\" data-kid=\"3-2-1-3-2-1\" data-name=\"manager profile image\" src=\"https://i.pravatar.cc/40?u=manager\">\n</div>\n</div>\n</div>\n</div>\n\n<main class=\"w-full px-16 pt-24 pb-32\" data-kid=\"3-3\" data-name=\"real-time asset registry section\">\n<div class=\"flex justify-between items-end mb-12\" data-kid=\"3-3-1\" data-name=\"registry header area\">\n<div data-kid=\"3-3-1-1\" data-name=\"registry header text group\">\n<h2 class=\"text-4xl font-extrabold tracking-tighter\" data-kid=\"3-3-1-1-1\" data-name=\"registry title\">Asset Registry</h2>\n<p class=\"text-slate-500 mt-2 font-medium\" data-kid=\"3-3-1-1-2\" data-name=\"registry description\">Monitoring 84 active units in the Eastern Region</p>\n</div>\n<div class=\"flex gap-2\" data-kid=\"3-3-1-2\" data-name=\"registry view controls container\">\n<button class=\"p-3 glass-panel rounded-xl hover:bg-white\" data-kid=\"3-3-1-2-1\" data-name=\"filter view button\"><i class=\"ti ti-filter text-xl\" data-kid=\"3-3-1-2-1-1\" data-name=\"filter icon\"></i></button>\n<button class=\"p-3 glass-panel rounded-xl hover:bg-white\" data-kid=\"3-3-1-2-2\" data-name=\"grid view button\"><i class=\"ti ti-layout-grid text-xl\" data-kid=\"3-3-1-2-2-1\" data-name=\"grid layout icon\"></i></button>\n</div>\n</div>\n<div class=\"grid grid-cols-4 gap-8\" data-kid=\"3-3-2\" data-name=\"asset registry card grid\">\n\n<div class=\"glass-panel rounded-[32px] p-8 flex flex-col gap-6 hover:shadow-2xl transition-all duration-500 group\" data-kid=\"3-3-2-1\" data-name=\"available unit card\">\n<div class=\"flex justify-between items-start\" data-kid=\"3-3-2-1-1\" data-name=\"available unit card header\">\n<div data-kid=\"3-3-2-1-1-1\" data-name=\"available unit info container\">\n<span class=\"text-[10px] font-black bg-[var(--color-light-blue)] text-[var(--color-primary)] px-2 py-1 rounded-md uppercase tracking-widest\" data-kid=\"3-3-2-1-1-1-1\" data-name=\"available status label\">Available</span>\n<h4 class=\"text-xl font-bold mt-2\" data-kid=\"3-3-2-1-1-1-2\" data-name=\"available unit ID\">Unit 88-X</h4>\n</div>\n<i class=\"ti ti-dots text-slate-400\" data-kid=\"3-3-2-1-1-2\" data-name=\"available unit menu icon\"></i>\n</div>\n<div class=\"flex items-center gap-6\" data-kid=\"3-3-2-1-2\" data-name=\"telemetry display container\">\n<div class=\"relative flex items-center justify-center\" data-kid=\"3-3-2-1-2-1\" data-name=\"safety ring graphic container\">\n<img alt=\"Safety ring\" class=\"w-20 h-20 safety-ring opacity-20\" data-kid=\"3-3-2-1-2-1-1\" data-name=\"safety ring background image\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/ring.svg\">\n<div class=\"absolute flex flex-col items-center\" data-kid=\"3-3-2-1-2-1-2\" data-name=\"safety score text container\">\n<span class=\"text-xl font-extrabold text-[var(--color-primary)]\" data-kid=\"3-3-2-1-2-1-2-1\" data-name=\"safety score value\">92</span>\n<span class=\"text-[8px] font-bold text-slate-400 uppercase\" data-kid=\"3-3-2-1-2-1-2-2\" data-name=\"safety score label\">Safety</span>\n</div>\n</div>\n<div class=\"space-y-3 flex-1\" data-kid=\"3-3-2-1-2-2\" data-name=\"performance metrics container\">\n<div class=\"flex justify-between items-center text-xs\" data-kid=\"3-3-2-1-2-2-1\" data-name=\"speed metric row\">\n<span class=\"font-bold text-slate-400\" data-kid=\"3-3-2-1-2-2-1-1\" data-name=\"speed metric label\">SPEED</span>\n<span class=\"font-extrabold tracking-tighter\" data-kid=\"3-3-2-1-2-2-1-2\" data-name=\"speed metric value\">0 mph</span>\n</div>\n<div class=\"flex justify-between items-center text-xs\" data-kid=\"3-3-2-1-2-2-2\" data-name=\"fuel metric row\">\n<span class=\"font-bold text-slate-400\" data-kid=\"3-3-2-1-2-2-2-1\" data-name=\"fuel metric label\">FUEL</span>\n<span class=\"font-extrabold tracking-tighter\" data-kid=\"3-3-2-1-2-2-2-2\" data-name=\"fuel metric value\">84%</span>\n</div>\n</div>\n</div>\n<button class=\"w-full py-3 rounded-2xl bg-slate-50 text-sm font-bold group-hover:bg-[var(--color-primary)] group-hover:text-white transition-colors\" data-kid=\"3-3-2-1-3\" data-name=\"view telemetry button\">\n          View Telemetry\n        </button>\n</div>\n\n<div class=\"glass-panel rounded-[32px] p-0 flex flex-col overflow-hidden ring-2 ring-[var(--color-danger-red)] animate-shake hover:shadow-2xl transition-all\" data-kid=\"3-3-2-2\" data-name=\"critical alert unit card\">\n<div class=\"relative h-40 w-full\" data-kid=\"3-3-2-2-1\" data-name=\"alert unit video container\">\n<video autoplay=\"\" class=\"w-full h-full object-cover\" data-dynamic=\"true\" data-kid=\"3-3-2-2-1-1\" data-name=\"alert unit monitor video\" data-reason=\"video playback controls are handled by browser/script\" loop=\"\" muted=\"\" playsinline=\"\" poster=\"https://images.pexels.com/videos/3010208/free-video-3010208.jpg?auto=compress&amp;cs=tinysrgb&amp;fit=crop&amp;h=240&amp;w=426\" preload=\"metadata\" src=\"https://videos.pexels.com/video-files/3010208/3010208-sd_426_240_24fps.mp4\"></video>\n<div class=\"absolute inset-0 bg-gradient-to-t from-black/60 to-transparent\" data-kid=\"3-3-2-2-1-2\" data-name=\"video gradient overlay\"></div>\n<div class=\"absolute top-4 left-4 flex gap-2\" data-kid=\"3-3-2-2-1-3\" data-name=\"alert status container\">\n<span class=\"bg-[var(--color-danger-red)] text-white text-[9px] font-black px-2 py-1 rounded-md uppercase animate-pulse\" data-kid=\"3-3-2-2-1-3-1\" data-name=\"critical status badge\">Critical</span>\n</div>\n</div>\n<div class=\"p-6 space-y-4\" data-kid=\"3-3-2-2-2\" data-name=\"alert details content area\">\n<div class=\"flex justify-between items-center\" data-kid=\"3-3-2-2-2-1\" data-name=\"alert details header\">\n<h4 class=\"text-xl font-bold\" data-kid=\"3-3-2-2-2-1-1\" data-name=\"alert unit ID\">Unit 42-B</h4>\n<i class=\"ti ti-alert-triangle text-[var(--color-danger-red)] animate-float\" data-kid=\"3-3-2-2-2-1-2\" data-name=\"alert attention icon\"></i>\n</div>\n<p class=\"text-xs text-slate-500 font-medium\" data-kid=\"3-3-2-2-2-2\" data-name=\"alert incident description\">Hard braking &amp; lane deviation detected on I-95 North.</p>\n<div class=\"flex gap-3\" data-kid=\"3-3-2-2-2-3\" data-name=\"alert response buttons container\">\n<button class=\"flex-1 py-3 rounded-xl bg-[var(--color-danger-red)] text-white text-xs font-bold shadow-lg shadow-red-200\" data-kid=\"3-3-2-2-2-3-1\" data-name=\"intervene button\">\n              Intervene\n            </button>\n<button class=\"px-4 py-3 rounded-xl bg-slate-100 text-slate-600 text-xs font-bold\" data-kid=\"3-3-2-2-2-3-2\" data-name=\"dismiss button\">\n              Dismiss\n            </button>\n</div>\n</div>\n</div>\n\n<div class=\"glass-panel rounded-[32px] p-8 flex flex-col gap-6 hover:shadow-2xl transition-all group\" data-kid=\"3-3-2-3\" data-name=\"busy unit card\">\n<div class=\"flex justify-between items-start\" data-kid=\"3-3-2-3-1\" data-name=\"busy unit header\">\n<div data-kid=\"3-3-2-3-1-1\" data-name=\"busy unit info container\">\n<span class=\"text-[10px] font-black bg-slate-100 text-slate-500 px-2 py-1 rounded-md uppercase tracking-widest\" data-kid=\"3-3-2-3-1-1-1\" data-name=\"busy status label\">On Trip</span>\n<h4 class=\"text-xl font-bold mt-2\" data-kid=\"3-3-2-3-1-1-2\" data-name=\"busy unit ID\">Unit 19-C</h4>\n</div>\n<i class=\"ti ti-dots text-slate-400\" data-kid=\"3-3-2-3-1-2\" data-name=\"busy unit menu icon\"></i>\n</div>\n<div class=\"flex items-center gap-6\" data-kid=\"3-3-2-3-2\" data-name=\"busy telemetry display\">\n<div class=\"relative flex items-center justify-center\" data-kid=\"3-3-2-3-2-1\" data-name=\"busy safety ring graphic container\">\n<img alt=\"Safety ring\" class=\"w-20 h-20 safety-ring opacity-20\" data-kid=\"3-3-2-3-2-1-1\" data-name=\"busy safety ring graphic\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/ring.svg\">\n<div class=\"absolute flex flex-col items-center\" data-kid=\"3-3-2-3-2-1-2\" data-name=\"busy safety score text\">\n<span class=\"text-xl font-extrabold text-[var(--color-primary)]\" data-kid=\"3-3-2-3-2-1-2-1\" data-name=\"busy safety score value\">85</span>\n<span class=\"text-[8px] font-bold text-slate-400 uppercase\" data-kid=\"3-3-2-3-2-1-2-2\" data-name=\"busy safety score label\">Safety</span>\n</div>\n</div>\n<div class=\"space-y-3 flex-1\" data-kid=\"3-3-2-3-2-2\" data-name=\"busy performance metrics\">\n<div class=\"flex justify-between items-center text-xs\" data-kid=\"3-3-2-3-2-2-1\" data-name=\"busy speed row\">\n<span class=\"font-bold text-slate-400\" data-kid=\"3-3-2-3-2-2-1-1\" data-name=\"busy speed label\">SPEED</span>\n<span class=\"font-extrabold tracking-tighter\" data-kid=\"3-3-2-3-2-2-1-2\" data-name=\"busy speed value\">62 mph</span>\n</div>\n<div class=\"flex justify-between items-center text-xs\" data-kid=\"3-3-2-3-2-2-2\" data-name=\"busy eta row\">\n<span class=\"font-bold text-slate-400\" data-kid=\"3-3-2-3-2-2-2-1\" data-name=\"busy eta label\">ETA</span>\n<span class=\"font-extrabold tracking-tighter\" data-kid=\"3-3-2-3-2-2-2-2\" data-name=\"busy eta value\">14 min</span>\n</div>\n</div>\n</div>\n<div class=\"w-full bg-slate-50 rounded-2xl p-4\" data-kid=\"3-3-2-3-3\" data-name=\"driver information card\">\n<div class=\"flex items-center gap-3\" data-kid=\"3-3-2-3-3-1\" data-name=\"driver info row\">\n<div class=\"w-8 h-8 rounded-full overflow-hidden bg-slate-200\" data-kid=\"3-3-2-3-3-1-1\" data-name=\"driver photo container\">\n<img alt=\"Driver\" data-kid=\"3-3-2-3-3-1-1-1\" data-name=\"driver portrait image\" src=\"https://i.pravatar.cc/32?u=driver1\">\n</div>\n<div class=\"flex-1\" data-kid=\"3-3-2-3-3-1-2\" data-name=\"driver name container\">\n<p class=\"text-[10px] font-bold text-slate-400 uppercase\" data-kid=\"3-3-2-3-3-1-2-1\" data-name=\"driver title label\">Driver</p>\n<p class=\"text-xs font-extrabold\" data-kid=\"3-3-2-3-3-1-2-2\" data-name=\"driver name\">Marcus Rivera</p>\n</div>\n<i class=\"ti ti-phone text-slate-400 text-lg\" data-kid=\"3-3-2-3-3-1-3\" data-name=\"driver contact icon\"></i>\n</div>\n</div>\n</div>\n\n<div class=\"glass-panel rounded-[32px] p-8 flex flex-col gap-6 hover:shadow-2xl transition-all group\" data-kid=\"3-3-2-4\" data-name=\"second available unit card\">\n<div class=\"flex justify-between items-start\" data-kid=\"3-3-2-4-1\" data-name=\"second available unit header\">\n<div data-kid=\"3-3-2-4-1-1\" data-name=\"second available unit info\">\n<span class=\"text-[10px] font-black bg-[var(--color-light-blue)] text-[var(--color-primary)] px-2 py-1 rounded-md uppercase tracking-widest\" data-kid=\"3-3-2-4-1-1-1\" data-name=\"available status label\">Available</span>\n<h4 class=\"text-xl font-bold mt-2\" data-kid=\"3-3-2-4-1-1-2\" data-name=\"unit ID\">Unit 03-S</h4>\n</div>\n<i class=\"ti ti-dots text-slate-400\" data-kid=\"3-3-2-4-1-2\" data-name=\"unit menu icon\"></i>\n</div>\n<div class=\"flex items-center gap-6\" data-kid=\"3-3-2-4-2\" data-name=\"telemetry container\">\n<div class=\"relative flex items-center justify-center\" data-kid=\"3-3-2-4-2-1\" data-name=\"safety ring graphic container\">\n<img alt=\"Safety ring\" class=\"w-20 h-20 safety-ring opacity-20\" data-kid=\"3-3-2-4-2-1-1\" data-name=\"safety ring graphic\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/ring.svg\">\n<div class=\"absolute flex flex-col items-center\" data-kid=\"3-3-2-4-2-1-2\" data-name=\"safety score text\">\n<span class=\"text-xl font-extrabold text-[var(--color-primary)]\" data-kid=\"3-3-2-4-2-1-2-1\" data-name=\"safety score value\">98</span>\n<span class=\"text-[8px] font-bold text-slate-400 uppercase\" data-kid=\"3-3-2-4-2-1-2-2\" data-name=\"safety score label\">Safety</span>\n</div>\n</div>\n<div class=\"space-y-3 flex-1\" data-kid=\"3-3-2-4-2-2\" data-name=\"performance metrics container\">\n<div class=\"flex justify-between items-center text-xs\" data-kid=\"3-3-2-4-2-2-1\" data-name=\"speed metric row\">\n<span class=\"font-bold text-slate-400\" data-kid=\"3-3-2-4-2-2-1-1\" data-name=\"speed metric label\">SPEED</span>\n<span class=\"font-extrabold tracking-tighter\" data-kid=\"3-3-2-4-2-2-1-2\" data-name=\"speed metric value\">0 mph</span>\n</div>\n<div class=\"flex justify-between items-center text-xs\" data-kid=\"3-3-2-4-2-2-2\" data-name=\"oils metric row\">\n<span class=\"font-bold text-slate-400\" data-kid=\"3-3-2-4-2-2-2-1\" data-name=\"oils metric label\">OILS</span>\n<span class=\"font-extrabold tracking-tighter text-[var(--color-success-green)]\" data-kid=\"3-3-2-4-2-2-2-2\" data-name=\"oils metric value\">Optimal</span>\n</div>\n</div>\n</div>\n<button class=\"w-full py-3 rounded-2xl bg-slate-50 text-sm font-bold group-hover:bg-[var(--color-primary)] group-hover:text-white transition-colors\" data-kid=\"3-3-2-4-3\" data-name=\"view telemetry button\">\n          View Telemetry\n        </button>\n</div>\n</div>\n</main>\n</div>",
