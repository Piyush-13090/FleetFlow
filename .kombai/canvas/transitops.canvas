      "html": "<link data-kid=\"1\" data-name=\"tabler icons stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" rel=\"stylesheet\">\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap');\n  \n  /* Applying local styles from frontend/src/index.css */\n  .glass-panel {\n    background: rgba(255, 255, 255, 0.75);\n    backdrop-filter: blur(16px) saturate(120%);\n    -webkit-backdrop-filter: blur(16px) saturate(120%);\n    border: 1px solid rgba(255, 255, 255, 0.4);\n  }\n\n  .input-glow:focus {\n    outline: none;\n    border-color: #2563EB;\n    box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.15);\n  }\n\n  .ripple-btn {\n    position: relative;\n    overflow: hidden;\n  }\n  \n  .animate-float {\n    animation: float 6s ease-in-out infinite;\n  }\n\n  @keyframes float {\n    0%, 100% { transform: translateY(0px); }\n    50% { transform: translateY(-12px); }\n  }\n\n  .dark-map-inset {\n    background: #0F172A;\n    background-image: radial-gradient(circle at 2px 2px, rgba(59, 130, 246, 0.1) 1px, transparent 0);\n    background-size: 24px 24px;\n  }\n</style>\n<div class=\"relative w-full h-[1024px] bg-[#F8FAFC] font-['Outfit'] overflow-hidden text-[#0F172A]\" data-kid=\"2\" data-name=\"dashboard layout container\">\n\n<div class=\"absolute top-[10%] left-[15%] w-[400px] h-[400px] bg-[#8B5CF6]/20 rounded-full blur-[100px]\" data-kid=\"2-1\" data-name=\"decorative blurred background blob\"></div>\n<div class=\"absolute bottom-[10%] right-[15%] w-[500px] h-[500px] bg-[#10B981]/20 rounded-full blur-[100px]\" data-kid=\"2-2\" data-name=\"decorative blurred background blob\"></div>\n<div class=\"relative z-10 flex flex-col h-full\" data-kid=\"2-3\" data-name=\"main dashboard content area\">\n\n<div class=\"flex-1 flex gap-6 p-8 pb-4\" data-kid=\"2-3-1\" data-name=\"top statistics panel group\">\n\n<div class=\"flex-1 glass-panel rounded-3xl p-6 flex flex-col\" data-kid=\"2-3-1-1\" data-name=\"safety analytics card\">\n<div class=\"flex items-center justify-between mb-6\" data-kid=\"2-3-1-1-1\" data-name=\"safety analytics header\">\n<h3 class=\"text-lg font-semibold flex items-center gap-2\" data-kid=\"2-3-1-1-1-1\" data-name=\"safety shield icon\">\n<i class=\"ti ti-shield-check text-blue-600\" data-kid=\"2-3-1-1-1-1-1\"></i> Safety Analytics\n          </h3>\n<span class=\"text-xs font-medium text-blue-600 bg-blue-50 px-2 py-1 rounded-full\" data-kid=\"2-3-1-1-1-2\" data-name=\"live status indicator\">LIVE</span>\n</div>\n<div class=\"flex-1 flex flex-col justify-center\" data-kid=\"2-3-1-1-2\" data-name=\"safety analytics data body\">\n<div class=\"text-5xl font-extrabold mb-1\" data-kid=\"2-3-1-1-2-1\" data-name=\"fleet safety score value\">94.2</div>\n<div class=\"text-sm font-medium text-gray-500 mb-8 uppercase tracking-wider\" data-kid=\"2-3-1-1-2-2\" data-name=\"fleet safety score label\">Fleet Safety Score</div>\n<div class=\"space-y-4\" data-kid=\"2-3-1-1-2-3\" data-name=\"safety metrics list\">\n<div class=\"flex items-center justify-between text-sm\" data-kid=\"2-3-1-1-2-3-1\" data-name=\"harsh braking metric\">\n<span class=\"text-gray-600\" data-kid=\"2-3-1-1-2-3-1-1\" data-name=\"harsh braking label\">Harsh Braking</span>\n<span class=\"font-bold text-green-600\" data-kid=\"2-3-1-1-2-3-1-2\" data-name=\"harsh braking value\">-12% <i class=\"ti ti-trending-down\" data-kid=\"2-3-1-1-2-3-1-2-1\" data-name=\"trending down icon\"></i></span>\n</div>\n<div class=\"w-full bg-gray-100 h-2 rounded-full overflow-hidden\" data-kid=\"2-3-1-1-2-3-2\" data-name=\"harsh braking progress bar\">\n<div class=\"bg-green-500 h-full w-[88%]\" data-kid=\"2-3-1-1-2-3-2-1\" data-name=\"harsh braking fill\"></div>\n</div>\n<div class=\"flex items-center justify-between text-sm\" data-kid=\"2-3-1-1-2-3-3\" data-name=\"speeding alerts metric\">\n<span class=\"text-gray-600\" data-kid=\"2-3-1-1-2-3-3-1\" data-name=\"speeding alerts label\">Speeding Alerts</span>\n<span class=\"font-bold text-red-600\" data-kid=\"2-3-1-1-2-3-3-2\" data-name=\"speeding alerts value\">+4% <i class=\"ti ti-trending-up\" data-kid=\"2-3-1-1-2-3-3-2-1\" data-name=\"trending up icon\"></i></span>\n</div>\n<div class=\"w-full bg-gray-100 h-2 rounded-full overflow-hidden\" data-kid=\"2-3-1-1-2-3-4\" data-name=\"speeding alerts progress bar\">\n<div class=\"bg-red-500 h-full w-[14%]\" data-kid=\"2-3-1-1-2-3-4-1\" data-name=\"speeding alerts fill\"></div>\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"flex-[1.5] glass-panel rounded-3xl p-8 relative overflow-hidden flex flex-col items-center justify-center text-center\" data-kid=\"2-3-1-2\" data-name=\"fleet operations center card\">\n<div class=\"absolute top-6 left-8 text-left\" data-kid=\"2-3-1-2-1\" data-name=\"fleet operations header\">\n<h3 class=\"text-xl font-bold\" data-kid=\"2-3-1-2-1-1\" data-name=\"fleet operations title\">Fleet Operations</h3>\n<p class=\"text-sm text-gray-500\" data-kid=\"2-3-1-2-1-2\" data-name=\"fleet operations subtitle\">Real-time unit distribution</p>\n</div>\n<div class=\"relative mt-12 mb-8\" data-kid=\"2-3-1-2-2\" data-name=\"fleet operations visualization container\">\n\n<div class=\"w-64 h-64 flex items-center justify-center border-[16px] border-blue-100 rounded-full relative\" data-kid=\"2-3-1-2-2-1\" data-name=\"active trips radial progress\">\n<img class=\"w-32 h-32 opacity-20 absolute\" data-kid=\"2-3-1-2-2-1-1\" data-name=\"radial balance icon\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/radial-balance.svg\" style=\"color: #3B82F6;\">\n<div class=\"text-center z-10\" data-kid=\"2-3-1-2-2-1-2\" data-name=\"active trips count container\">\n<div class=\"text-6xl font-black text-blue-600\" data-kid=\"2-3-1-2-2-1-2-1\" data-name=\"active trips count\">1,204</div>\n<div class=\"text-xs font-bold uppercase tracking-widest text-blue-400\" data-kid=\"2-3-1-2-2-1-2-2\" data-name=\"active trips label\">Active Trips</div>\n</div>\n\n<svg class=\"absolute inset-0 w-full h-full -rotate-90\" data-kid=\"2-3-1-2-2-1-3\" data-name=\"radial progress ring\">\n<circle cx=\"128\" cy=\"128\" fill=\"none\" r=\"112\" stroke=\"#2563EB\" stroke-dasharray=\"703\" stroke-dashoffset=\"140\" stroke-linecap=\"round\" stroke-width=\"16\" data-kid=\"3\"></circle>\n</svg>\n</div>\n\n<div class=\"absolute -bottom-8 -right-12 w-80 animate-float drop-shadow-2xl\" data-kid=\"2-3-1-2-2-2\" data-name=\"floating electric van image container\">\n<img alt=\"Modern electric delivery van\" class=\"w-full\" data-kid=\"2-3-1-2-2-2-1\" data-name=\"modern electric delivery van image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1594200879785-b6ee4fc48712?auto=format&amp;w=800&amp;q=80&amp;fit=crop\">\n</div>\n</div>\n<div class=\"grid grid-cols-3 gap-8 w-full px-4\" data-kid=\"2-3-1-2-3\" data-name=\"fleet stats grid\">\n<div class=\"text-left\" data-kid=\"2-3-1-2-3-1\" data-name=\"utilized metric\">\n<div class=\"text-xs font-bold text-gray-400 uppercase\" data-kid=\"2-3-1-2-3-1-1\" data-name=\"utilized label\">Utilized</div>\n<div class=\"text-2xl font-bold\" data-kid=\"2-3-1-2-3-1-2\" data-name=\"utilized value\">88%</div>\n</div>\n<div class=\"text-left border-x border-gray-100 px-8\" data-kid=\"2-3-1-2-3-2\" data-name=\"on-route metric\">\n<div class=\"text-xs font-bold text-gray-400 uppercase\" data-kid=\"2-3-1-2-3-2-1\" data-name=\"on-route label\">On Route</div>\n<div class=\"text-2xl font-bold\" data-kid=\"2-3-1-2-3-2-2\" data-name=\"on-route value\">842</div>\n</div>\n<div class=\"text-left\" data-kid=\"2-3-1-2-3-3\" data-name=\"standby metric\">\n<div class=\"text-xs font-bold text-gray-400 uppercase\" data-kid=\"2-3-1-2-3-3-1\" data-name=\"standby label\">Standby</div>\n<div class=\"text-2xl font-bold\" data-kid=\"2-3-1-2-3-3-2\" data-name=\"standby value\">156</div>\n</div>\n</div>\n</div>\n\n<div class=\"flex-1 glass-panel rounded-3xl p-6 flex flex-col\" data-kid=\"2-3-1-3\" data-name=\"efficiency log card\">\n<div class=\"flex items-center justify-between mb-6\" data-kid=\"2-3-1-3-1\" data-name=\"efficiency log header\">\n<h3 class=\"text-lg font-semibold flex items-center gap-2\" data-kid=\"2-3-1-3-1-1\" data-name=\"efficiency log title\">\n<i class=\"ti ti-bolt text-amber-500\" data-kid=\"2-3-1-3-1-1-1\" data-name=\"efficiency bolt icon\"></i> Efficiency Log\n          </h3>\n<i class=\"ti ti-dots-vertical text-gray-400\" data-kid=\"2-3-1-3-1-2\" data-name=\"efficiency log menu dots\"></i>\n</div>\n<div class=\"flex-1 space-y-6\" data-kid=\"2-3-1-3-2\" data-name=\"efficiency log body\">\n<div class=\"p-4 bg-amber-50 rounded-2xl border border-amber-100\" data-kid=\"2-3-1-3-2-1\" data-name=\"fuel efficiency highlight\">\n<div class=\"flex items-center justify-between mb-2\" data-kid=\"2-3-1-3-2-1-1\" data-name=\"fuel efficiency title\">\n<span class=\"text-xs font-bold text-amber-700 uppercase\" data-kid=\"2-3-1-3-2-1-1-1\" data-name=\"fuel efficiency label\">Fuel Efficiency</span>\n<span class=\"text-lg font-bold\" data-kid=\"2-3-1-3-2-1-1-2\" data-name=\"fuel efficiency value\">18.4 <span class=\"text-xs\" data-kid=\"2-3-1-3-2-1-1-2-1\" data-name=\"fuel efficiency unit\">km/L</span></span>\n</div>\n<div class=\"w-full bg-amber-200/30 h-1.5 rounded-full overflow-hidden\" data-kid=\"2-3-1-3-2-1-2\" data-name=\"fuel efficiency progress track\">\n<div class=\"bg-amber-500 h-full w-[72%]\" data-kid=\"2-3-1-3-2-1-2-1\" data-name=\"fuel efficiency progress fill\"></div>\n</div>\n</div>\n<div class=\"flex-1\" data-kid=\"2-3-1-3-2-2\" data-name=\"roi distribution container\">\n<div class=\"text-xs font-bold text-gray-400 uppercase mb-4\" data-kid=\"2-3-1-3-2-2-1\" data-name=\"roi distribution title\">Daily ROI Distribution</div>\n<div class=\"flex items-end gap-2 h-32\" data-kid=\"2-3-1-3-2-2-2\" data-name=\"roi chart container\">\n<div class=\"flex-1 bg-blue-100 rounded-t-lg h-[40%]\" data-kid=\"2-3-1-3-2-2-2-1\" data-name=\"roi bar 1\"></div>\n<div class=\"flex-1 bg-blue-100 rounded-t-lg h-[60%]\" data-kid=\"2-3-1-3-2-2-2-2\" data-name=\"roi bar 2\"></div>\n<div class=\"flex-1 bg-blue-600 rounded-t-lg h-[90%]\" data-kid=\"2-3-1-3-2-2-2-3\" data-name=\"roi bar 3\"></div>\n<div class=\"flex-1 bg-blue-100 rounded-t-lg h-[50%]\" data-kid=\"2-3-1-3-2-2-2-4\" data-name=\"roi bar 4\"></div>\n<div class=\"flex-1 bg-blue-100 rounded-t-lg h-[70%]\" data-kid=\"2-3-1-3-2-2-2-5\" data-name=\"roi bar 5\"></div>\n<div class=\"flex-1 bg-blue-100 rounded-t-lg h-[45%]\" data-kid=\"2-3-1-3-2-2-2-6\" data-name=\"roi bar 6\"></div>\n<div class=\"flex-1 bg-blue-100 rounded-t-lg h-[30%]\" data-kid=\"2-3-1-3-2-2-2-7\" data-name=\"roi bar 7\"></div>\n</div>\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"h-24 glass-panel flex items-center px-8 border-y border-white/40 shadow-xl relative z-20\" data-kid=\"2-3-2\" data-name=\"navigation waistband\">\n<div class=\"flex items-center gap-3 mr-12\" data-kid=\"2-3-2-1\" data-name=\"branding container\">\n<div class=\"w-10 h-10 bg-blue-600 rounded-xl flex items-center justify-center text-white\" data-kid=\"2-3-2-1-1\" data-name=\"truck logo icon container\">\n<i class=\"ti ti-truck text-2xl\" data-kid=\"2-3-2-1-1-1\" data-name=\"truck icon\"></i>\n</div>\n<span class=\"text-2xl font-black tracking-tight\" data-kid=\"2-3-2-1-2\" data-name=\"brand name\">Transit<span class=\"text-blue-600\" data-kid=\"2-3-2-1-2-1\" data-name=\"brand name suffix\">Ops</span></span>\n</div>\n<div class=\"flex-1 max-w-xl relative\" data-kid=\"2-3-2-2\" data-name=\"search input container\">\n<i class=\"ti ti-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-400\" data-kid=\"2-3-2-2-1\" data-name=\"search icon\"></i>\n<input class=\"w-full bg-white/50 border border-white/80 h-12 rounded-2xl pl-12 pr-4 text-sm input-glow transition-all\" data-kid=\"2-3-2-2-2\" data-name=\"search text field\" placeholder=\"Search vehicles, drivers, or active trips...\" type=\"text\">\n</div>\n<div class=\"flex items-center gap-6 ml-auto\" data-kid=\"2-3-2-3\" data-name=\"user profile navigation group\">\n<div class=\"flex items-center gap-2 px-4 py-2 bg-gray-100 rounded-xl cursor-pointer hover:bg-gray-200 transition-colors\" data-kid=\"2-3-2-3-1\" data-name=\"region selector\">\n<i class=\"ti ti-map-pin text-blue-600\" data-kid=\"2-3-2-3-1-1\" data-name=\"map pin icon\"></i>\n<span class=\"text-sm font-semibold\" data-kid=\"2-3-2-3-1-2\" data-name=\"region label\">Global Region</span>\n<i class=\"ti ti-chevron-down text-gray-400\" data-kid=\"2-3-2-3-1-3\" data-name=\"chevron down icon\"></i>\n</div>\n<div class=\"w-px h-8 bg-gray-200\" data-kid=\"2-3-2-3-2\" data-name=\"divider line\"></div>\n<div class=\"flex items-center gap-3\" data-kid=\"2-3-2-3-3\" data-name=\"manager profile\">\n<div class=\"text-right\" data-kid=\"2-3-2-3-3-1\" data-name=\"manager profile info\">\n<div class=\"text-sm font-bold\" data-kid=\"2-3-2-3-3-1-1\" data-name=\"manager name\">Alex Johnson</div>\n<div class=\"text-[10px] font-bold text-gray-400 uppercase tracking-widest\" data-kid=\"2-3-2-3-3-1-2\" data-name=\"manager role\">Fleet Manager</div>\n</div>\n<div class=\"w-12 h-12 rounded-2xl border-2 border-white shadow-sm overflow-hidden bg-blue-100 flex items-center justify-center\" data-kid=\"2-3-2-3-3-2\" data-name=\"manager avatar container\">\n<img class=\"w-full h-full object-cover\" data-kid=\"2-3-2-3-3-2-1\" data-name=\"manager avatar image\" src=\"https://i.pravatar.cc/100?u=transitops\">\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"flex-1 flex flex-col overflow-hidden\" data-kid=\"2-3-3\" data-name=\"monitoring section\">\n\n<div class=\"h-10 bg-blue-600 flex items-center overflow-hidden\" data-kid=\"2-3-3-1\" data-name=\"notification ticker tape\">\n<div class=\"flex items-center gap-12 whitespace-nowrap animate-[marquee_30s_linear_infinite] px-8\" data-kid=\"2-3-3-1-1\" data-name=\"ticker content\">\n<div class=\"flex items-center gap-2 text-white text-xs font-bold\" data-kid=\"2-3-3-1-1-1\" data-name=\"ticker alert item 1\">\n<span class=\"bg-red-500 px-1.5 py-0.5 rounded uppercase text-[10px]\" data-kid=\"2-3-3-1-1-1-1\" data-name=\"alert badge\">Alert</span>\n             Unit 42: Hard braking detected at Sector 7G • 2m ago\n           </div>\n<div class=\"flex items-center gap-2 text-white text-xs font-medium\" data-kid=\"2-3-3-1-1-2\" data-name=\"ticker update item 2\">\n<span class=\"bg-blue-400 px-1.5 py-0.5 rounded uppercase text-[10px]\" data-kid=\"2-3-3-1-1-2-1\" data-name=\"update badge\">Update</span>\n             Unit 18: Rerouted due to heavy traffic on I-95\n           </div>\n<div class=\"flex items-center gap-2 text-white text-xs font-medium\" data-kid=\"2-3-3-1-1-3\" data-name=\"ticker notice item 3\">\n<span class=\"bg-amber-400 px-1.5 py-0.5 rounded uppercase text-[10px] text-amber-900\" data-kid=\"2-3-3-1-1-3-1\" data-name=\"notice badge\">Notice</span>\n             Alex (Driver): Dispatching trip to Jersey City\n           </div>\n\n<div class=\"flex items-center gap-2 text-white text-xs font-bold\" data-kid=\"2-3-3-1-1-4\" data-name=\"ticker alert duplicate item\">\n<span class=\"bg-red-500 px-1.5 py-0.5 rounded uppercase text-[10px]\" data-kid=\"2-3-3-1-1-4-1\" data-name=\"alert badge duplicate\">Alert</span>\n             Unit 42: Hard braking detected at Sector 7G • 2m ago\n           </div>\n</div>\n</div>\n<div class=\"flex-1 flex gap-6 p-8 pt-6\" data-kid=\"2-3-3-2\" data-name=\"driver status and map area\">\n\n<div class=\"flex-1 glass-panel rounded-3xl overflow-hidden flex flex-col\" data-kid=\"2-3-3-2-1\" data-name=\"active drivers list\">\n<div class=\"p-6 border-b border-gray-100 flex items-center justify-between bg-white/30\" data-kid=\"2-3-3-2-1-1\" data-name=\"drivers list header\">\n<h3 class=\"font-bold\" data-kid=\"2-3-3-2-1-1-1\" data-name=\"drivers title\">Active Drivers</h3>\n<span class=\"text-xs font-bold text-gray-400\" data-kid=\"2-3-3-2-1-1-2\" data-name=\"drivers count status\">24 Online</span>\n</div>\n<div class=\"flex-1 overflow-y-auto p-2 space-y-1\" data-kid=\"2-3-3-2-1-2\" data-name=\"drivers scroll area\">\n\n<div class=\"flex items-center gap-4 p-4 rounded-2xl hover:bg-white/50 transition-colors group\" data-kid=\"2-3-3-2-1-2-1\" data-name=\"driver 1 card\">\n<img class=\"w-8 h-8\" data-kid=\"2-3-3-2-1-2-1-1\" data-name=\"driver 1 icon\" src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/oncoming-automobile.svg\">\n<div class=\"flex-1\" data-kid=\"2-3-3-2-1-2-1-2\" data-name=\"driver 1 details\">\n<div class=\"text-sm font-bold\" data-kid=\"2-3-3-2-1-2-1-2-1\" data-name=\"driver 1 name\">Marco Rossi</div>\n<div class=\"text-[10px] text-gray-400\" data-kid=\"2-3-3-2-1-2-1-2-2\" data-name=\"driver 1 route info\">Unit-77A • Route A1</div>\n</div>\n<div class=\"text-right\" data-kid=\"2-3-3-2-1-2-1-3\" data-name=\"driver 1 status container\">\n<div class=\"text-[10px] font-bold text-green-600 bg-green-50 px-2 py-0.5 rounded-full\" data-kid=\"2-3-3-2-1-2-1-3-1\" data-name=\"driver 1 active badge\">ACTIVE</div>\n<div class=\"text-[10px] text-gray-400 mt-1\" data-kid=\"2-3-3-2-1-2-1-3-2\" data-name=\"driver 1 eta info\">ETA 12m</div>\n</div>\n</div>\n\n<div class=\"flex items-center gap-4 p-4 rounded-2xl hover:bg-white/50 transition-colors group\" data-kid=\"2-3-3-2-1-2-2\" data-name=\"driver 2 card\">\n<img class=\"w-8 h-8\" data-kid=\"2-3-3-2-1-2-2-1\" data-name=\"driver 2 icon\" src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/oncoming-automobile.svg\">\n<div class=\"flex-1\" data-kid=\"2-3-3-2-1-2-2-2\" data-name=\"driver 2 details\">\n<div class=\"text-sm font-bold\" data-kid=\"2-3-3-2-1-2-2-2-1\" data-name=\"driver 2 name\">Sarah Chen</div>\n<div class=\"text-[10px] text-gray-400\" data-kid=\"2-3-3-2-1-2-2-2-2\" data-name=\"driver 2 route info\">Unit-12B • Route C4</div>\n</div>\n<div class=\"text-right\" data-kid=\"2-3-3-2-1-2-2-3\" data-name=\"driver 2 status container\">\n<div class=\"text-[10px] font-bold text-green-600 bg-green-50 px-2 py-0.5 rounded-full\" data-kid=\"2-3-3-2-1-2-2-3-1\" data-name=\"driver 2 active badge\">ACTIVE</div>\n<div class=\"text-[10px] text-gray-400 mt-1\" data-kid=\"2-3-3-2-1-2-2-3-2\" data-name=\"driver 2 eta info\">ETA 34m</div>\n</div>\n</div>\n\n<div class=\"flex items-center gap-4 p-4 rounded-2xl hover:bg-white/50 transition-colors group opacity-60\" data-kid=\"2-3-3-2-1-2-3\" data-name=\"driver 3 card\">\n<img class=\"w-8 h-8\" data-kid=\"2-3-3-2-1-2-3-1\" data-name=\"driver 3 icon\" src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/sleeping-face.svg\">\n<div class=\"flex-1\" data-kid=\"2-3-3-2-1-2-3-2\" data-name=\"driver 3 details\">\n<div class=\"text-sm font-bold\" data-kid=\"2-3-3-2-1-2-3-2-1\" data-name=\"driver 3 name\">Dave Miller</div>\n<div class=\"text-[10px] text-gray-400\" data-kid=\"2-3-3-2-1-2-3-2-2\" data-name=\"driver 3 route info\">Standby</div>\n</div>\n<div class=\"text-right\" data-kid=\"2-3-3-2-1-2-3-3\" data-name=\"driver 3 status container\">\n<div class=\"text-[10px] font-bold text-gray-400 bg-gray-50 px-2 py-0.5 rounded-full uppercase\" data-kid=\"2-3-3-2-1-2-3-3-1\" data-name=\"driver 3 status badge\">Resting</div>\n</div>\n</div>\n\n<div class=\"flex items-center gap-4 p-4 rounded-2xl hover:bg-white/50 transition-colors group opacity-60\" data-kid=\"2-3-3-2-1-2-4\" data-name=\"driver 4 card\">\n<img class=\"w-8 h-8\" data-kid=\"2-3-3-2-1-2-4-1\" data-name=\"driver 4 icon\" src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/sleeping-face.svg\">\n<div class=\"flex-1\" data-kid=\"2-3-3-2-1-2-4-2\" data-name=\"driver 4 details\">\n<div class=\"text-sm font-bold\" data-kid=\"2-3-3-2-1-2-4-2-1\" data-name=\"driver 4 name\">Elena Vance</div>\n<div class=\"text-[10px] text-gray-400\" data-kid=\"2-3-3-2-1-2-4-2-2\" data-name=\"driver 4 route info\">Standby</div>\n</div>\n<div class=\"text-right\" data-kid=\"2-3-3-2-1-2-4-3\" data-name=\"driver 4 status container\">\n<div class=\"text-[10px] font-bold text-gray-400 bg-gray-50 px-2 py-0.5 rounded-full uppercase\" data-kid=\"2-3-3-2-1-2-4-3-1\" data-name=\"driver 4 status badge\">Resting</div>\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"flex-[1.5] glass-panel rounded-3xl overflow-hidden relative dark-map-inset p-1\" data-kid=\"2-3-3-2-2\" data-name=\"map inset panel\">\n<div class=\"absolute inset-0 opacity-40\" data-kid=\"2-3-3-2-2-1\" data-name=\"map content layer\">\n\n<svg class=\"w-full h-full\" data-kid=\"2-3-3-2-2-1-1\" data-name=\"map route simulation svg\" viewbox=\"0 0 800 500\">\n<path class=\"animate-[dash_2s_linear_infinite]\" d=\"M100 100 Q 400 250 700 400\" fill=\"none\" stroke=\"#3B82F6\" stroke-dasharray=\"4\" stroke-width=\"2\" data-kid=\"4\"></path>\n<path class=\"animate-[dash_3s_linear_infinite]\" d=\"M150 400 Q 400 250 650 100\" fill=\"none\" stroke=\"#10B981\" stroke-dasharray=\"4\" stroke-width=\"2\" data-kid=\"5\"></path>\n<circle class=\"animate-pulse\" cx=\"400\" cy=\"250\" fill=\"#2563EB\" r=\"8\" data-kid=\"6\"></circle>\n<circle cx=\"100\" cy=\"100\" fill=\"#60A5FA\" r=\"4\" data-kid=\"7\"></circle>\n<circle cx=\"700\" cy=\"400\" fill=\"#60A5FA\" r=\"4\" data-kid=\"8\"></circle>\n<circle cx=\"150\" cy=\"400\" fill=\"#34D399\" r=\"4\" data-kid=\"9\"></circle>\n<circle cx=\"650\" cy=\"100\" fill=\"#34D399\" r=\"4\" data-kid=\"10\"></circle>\n</svg>\n<style data-kid=\"11\">\n                @keyframes dash {\n                  to { stroke-dashoffset: -8; }\n                }\n                @keyframes marquee {\n                  0% { transform: translateX(0); }\n                  100% { transform: translateX(-50%); }\n                }\n              </style>\n</div>\n<div class=\"absolute top-6 left-6 flex flex-col gap-2\" data-kid=\"2-3-3-2-2-2\" data-name=\"map legend container\">\n<div class=\"glass-panel bg-black/40 backdrop-blur-md border-white/10 p-3 rounded-2xl flex items-center gap-3\" data-kid=\"2-3-3-2-2-2-1\" data-name=\"map legend item 1\">\n<div class=\"w-2 h-2 rounded-full bg-blue-500 animate-pulse\" data-kid=\"2-3-3-2-2-2-1-1\" data-name=\"legend item 1 dot\"></div>\n<div class=\"text-[10px] font-bold text-white uppercase tracking-widest\" data-kid=\"2-3-3-2-2-2-1-2\" data-name=\"legend item 1 label\">Active Corridor Alpha</div>\n</div>\n<div class=\"glass-panel bg-black/40 backdrop-blur-md border-white/10 p-3 rounded-2xl flex items-center gap-3\" data-kid=\"2-3-3-2-2-2-2\" data-name=\"map legend item 2\">\n<div class=\"w-2 h-2 rounded-full bg-emerald-500 animate-pulse\" data-kid=\"2-3-3-2-2-2-2-1\" data-name=\"legend item 2 dot\"></div>\n<div class=\"text-[10px] font-bold text-white uppercase tracking-widest\" data-kid=\"2-3-3-2-2-2-2-2\" data-name=\"legend item 2 label\">Supply Chain Beta</div>\n</div>\n</div>\n<div class=\"absolute bottom-6 right-6\" data-kid=\"2-3-3-2-2-3\" data-name=\"map stats container\">\n<div class=\"glass-panel bg-black/60 backdrop-blur-xl border-white/20 p-4 rounded-3xl flex gap-6\" data-kid=\"2-3-3-2-2-3-1\" data-name=\"map stats block\">\n<div class=\"text-center\" data-kid=\"2-3-3-2-2-3-1-1\" data-name=\"map stat 1\">\n<div class=\"text-xl font-black text-white\" data-kid=\"2-3-3-2-2-3-1-1-1\" data-name=\"map stat 1 value\">42m</div>\n<div class=\"text-[8px] text-gray-400 font-bold uppercase\" data-kid=\"2-3-3-2-2-3-1-1-2\" data-name=\"map stat 1 label\">Avg Delivery</div>\n</div>\n<div class=\"w-px h-8 bg-white/10\" data-kid=\"2-3-3-2-2-3-1-2\" data-name=\"stat divider\"></div>\n<div class=\"text-center\" data-kid=\"2-3-3-2-2-3-1-3\" data-name=\"map stat 2\">\n<div class=\"text-xl font-black text-white\" data-kid=\"2-3-3-2-2-3-1-3-1\" data-name=\"map stat 2 value\">99.8%</div>\n<div class=\"text-[8px] text-gray-400 font-bold uppercase\" data-kid=\"2-3-3-2-2-3-1-3-2\" data-name=\"map stat 2 label\">SLA Success</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>",
