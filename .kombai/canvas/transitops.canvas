      "html": "<link data-kid=\"1\" data-name=\"tabler icons stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" rel=\"stylesheet\">\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap');\n  \n  :root {\n    --ink-950: #0A0F1E;\n    --ink-800: #1E293B;\n    --ink-600: #475569;\n    --ink-400: #94A3B8;\n    --ink-200: #E2E8F0;\n    --paper: #FFFFFF;\n    --canvas: #FBFCFD;\n    --accent: #2563EB;\n    --accent-tint: #EFF4FF;\n    --positive: #059669;\n    --warning: #D97706;\n    --critical: #DC2626;\n  }\n\n  .glass-panel {\n    background: rgba(255, 255, 255, 0.7);\n    backdrop-filter: blur(20px) saturate(160%);\n    -webkit-backdrop-filter: blur(20px) saturate(160%);\n    border: 1px solid rgba(255, 255, 255, 0.4);\n    box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.07);\n  }\n\n  .glass-panel-dark {\n    background: rgba(10, 15, 30, 0.6);\n    backdrop-filter: blur(12px);\n    -webkit-backdrop-filter: blur(12px);\n    border: 1px solid rgba(255, 255, 255, 0.1);\n  }\n\n  .tabular-nums { font-variant-numeric: tabular-nums; }\n  \n  .animate-float {\n    animation: float 6s ease-in-out infinite;\n  }\n  @keyframes float {\n    0%, 100% { transform: translateY(0px); }\n    50% { transform: translateY(-10px); }\n  }\n\n  .map-dots {\n    background-image: radial-gradient(circle at 1px 1px, rgba(59, 130, 246, 0.15) 1px, transparent 0);\n    background-size: 32px 32px;\n  }\n\n  .scroll-hide::-webkit-scrollbar { display: none; }\n  .scroll-hide { -ms-overflow-style: none; scrollbar-width: none; }\n</style>\n<div class=\"flex h-[1024px] bg-[#FBFCFD] font-['Outfit'] text-[#1E293B] overflow-hidden\" data-kid=\"2\" data-name=\"fleet dashboard app layout\">\n\n<aside class=\"w-20 bg-[#0A0F1E] flex flex-col items-center py-8 border-r border-white/10 relative z-50\" data-kid=\"2-1\" data-name=\"sidebar navigation rail\">\n<div class=\"w-12 h-12 bg-[#2563EB] rounded-2xl flex items-center justify-center text-white mb-12\" data-kid=\"2-1-1\" data-name=\"app brand logo icon container\">\n<i class=\"ti ti-truck text-2xl\" data-kid=\"2-1-1-1\" data-name=\"truck icon\"></i>\n</div>\n<nav class=\"flex flex-col gap-8\" data-kid=\"2-1-2\" data-name=\"primary navigation links\">\n<a class=\"text-white opacity-100 hover:opacity-100 transition-opacity\" data-kid=\"2-1-2-1\" data-name=\"dashboard navigation link\" href=\"#\"><i class=\"ti ti-layout-dashboard text-2xl\" data-kid=\"2-1-2-1-1\" data-name=\"dashboard icon\"></i></a>\n<a class=\"text-white opacity-40 hover:opacity-100 transition-opacity\" data-kid=\"2-1-2-2\" data-name=\"deliveries navigation link\" href=\"#\"><i class=\"ti ti-truck-delivery text-2xl\" data-kid=\"2-1-2-2-1\" data-name=\"truck delivery icon\"></i></a>\n<a class=\"text-white opacity-40 hover:opacity-100 transition-opacity\" data-kid=\"2-1-2-3\" data-name=\"users navigation link\" href=\"#\"><i class=\"ti ti-users text-2xl\" data-kid=\"2-1-2-3-1\" data-name=\"users icon\"></i></a>\n<a class=\"text-white opacity-40 hover:opacity-100 transition-opacity\" data-kid=\"2-1-2-4\" data-name=\"routes navigation link\" href=\"#\"><i class=\"ti ti-route text-2xl\" data-kid=\"2-1-2-4-1\" data-name=\"route icon\"></i></a>\n<a class=\"text-white opacity-40 hover:opacity-100 transition-opacity\" data-kid=\"2-1-2-5\" data-name=\"maintenance navigation link\" href=\"#\"><i class=\"ti ti-wrench text-2xl\" data-kid=\"2-1-2-5-1\" data-name=\"wrench icon\"></i></a>\n<a class=\"text-white opacity-40 hover:opacity-100 transition-opacity\" data-kid=\"2-1-2-6\" data-name=\"analytics navigation link\" href=\"#\"><i class=\"ti ti-bar-chart text-2xl\" data-kid=\"2-1-2-6-1\" data-name=\"bar chart icon\"></i></a>\n</nav>\n<div class=\"mt-auto flex flex-col gap-8\" data-kid=\"2-1-3\" data-name=\"sidebar utility section\">\n<a class=\"text-white opacity-40 hover:opacity-100 transition-opacity\" data-kid=\"2-1-3-1\" data-name=\"notifications navigation link\" href=\"#\"><i class=\"ti ti-bell text-2xl\" data-kid=\"2-1-3-1-1\" data-name=\"bell icon\"></i></a>\n<div class=\"w-10 h-10 rounded-xl bg-blue-500/20 border border-blue-500/30 overflow-hidden\" data-kid=\"2-1-3-2\" data-name=\"user profile picture container\">\n<img class=\"w-full h-full object-cover grayscale brightness-110\" data-kid=\"2-1-3-2-1\" data-name=\"user profile image\" src=\"https://i.pravatar.cc/100?u=piyush\">\n</div>\n</div>\n</aside>\n\n<main class=\"flex-1 flex flex-col relative overflow-hidden\" data-kid=\"2-2\" data-name=\"main dashboard content area\">\n\n<div class=\"absolute top-0 left-0 w-full h-[600px] bg-[#0A0F1E] map-dots relative overflow-hidden\" data-kid=\"2-2-1\" data-name=\"hero map background layer\">\n\n<div class=\"absolute -top-20 -left-20 w-96 h-96 bg-[#8B5CF6]/10 rounded-full blur-[100px]\" data-kid=\"2-2-1-1\" data-name=\"purple decorative blob\"></div>\n<div class=\"absolute bottom-20 right-40 w-[500px] h-[500px] bg-[#10B981]/10 rounded-full blur-[120px]\" data-kid=\"2-2-1-2\" data-name=\"green decorative blob\"></div>\n\n<svg class=\"absolute inset-0 w-full h-full opacity-30\" data-kid=\"2-2-1-3\" data-name=\"simulated map route visualization\" viewbox=\"0 0 1200 600\">\n<path d=\"M100 450 Q 300 400 500 480 T 900 420\" fill=\"none\" stroke=\"#2563EB\" stroke-dasharray=\"8 6\" stroke-width=\"2\" data-kid=\"3\"></path>\n<circle cx=\"100\" cy=\"450\" fill=\"#059669\" r=\"6\" data-kid=\"4\"></circle>\n<circle cx=\"900\" cy=\"420\" fill=\"#2563EB\" r=\"4\" data-kid=\"5\"></circle>\n<circle class=\"animate-pulse\" cx=\"500\" cy=\"480\" fill=\"#D97706\" r=\"8\" data-kid=\"6\"></circle>\n</svg>\n\n<header class=\"absolute top-6 left-6 right-6 h-16 glass-panel rounded-2xl px-6 flex items-center justify-between z-40\" data-kid=\"2-2-1-4\" data-name=\"floating top navigation bar\">\n<div class=\"flex items-center gap-6\" data-kid=\"2-2-1-4-1\" data-name=\"top nav left tools\">\n<div class=\"flex items-center gap-2 bg-white/50 px-4 py-2 rounded-xl border border-white/80\" data-kid=\"2-2-1-4-1-1\" data-name=\"location selector dropdown\">\n<i class=\"ti ti-world text-blue-600\" data-kid=\"2-2-1-4-1-1-1\" data-name=\"world icon\"></i>\n<span class=\"text-sm font-bold\" data-kid=\"2-2-1-4-1-1-2\" data-name=\"location name text\">NE Fleet Hub</span>\n<i class=\"ti ti-chevron-down text-gray-400\" data-kid=\"2-2-1-4-1-1-3\" data-name=\"chevron down icon\"></i>\n</div>\n<div class=\"relative w-96\" data-kid=\"2-2-1-4-1-2\" data-name=\"search input container\">\n<i class=\"ti ti-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-400\" data-kid=\"2-2-1-4-1-2-1\" data-name=\"search icon\"></i>\n<input class=\"w-full bg-white/40 border border-white/60 h-10 rounded-xl pl-12 pr-4 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500/20\" data-kid=\"2-2-1-4-1-2-2\" data-name=\"search input field\" placeholder=\"Search vehicles, routes, drivers...\" type=\"text\">\n</div>\n</div>\n<div class=\"flex items-center gap-6\" data-kid=\"2-2-1-4-2\" data-name=\"top nav right tools\">\n<div class=\"flex items-center gap-4 text-xs font-bold text-gray-500 uppercase tracking-widest\" data-kid=\"2-2-1-4-2-1\" data-name=\"weather and time status section\">\n<div class=\"flex items-center gap-2\" data-dynamic=\"true\" data-kid=\"2-2-1-4-2-1-1\" data-name=\"live time status\" data-reason=\"text updated by script to show current time\">\n<i class=\"ti ti-clock\" data-kid=\"2-2-1-4-2-1-1-1\" data-name=\"clock icon\"></i> 13:24:33\n            </div>\n<div class=\"w-px h-4 bg-gray-200\" data-kid=\"2-2-1-4-2-1-2\" data-name=\"separator\"></div>\n<div class=\"flex items-center gap-2\" data-kid=\"2-2-1-4-2-1-3\" data-name=\"live temperature status\">\n<i class=\"ti ti-sun\" data-kid=\"2-2-1-4-2-1-3-1\" data-name=\"sun icon\"></i> 74°F\n            </div>\n</div>\n<button class=\"w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center text-white shadow-lg hover:scale-105 transition-transform\" data-kid=\"2-2-1-4-2-2\" data-name=\"create new record button\">\n<i class=\"ti ti-plus\" data-kid=\"2-2-1-4-2-2-1\" data-name=\"plus icon\"></i>\n</button>\n</div>\n</header>\n\n<div class=\"absolute top-28 left-6 flex flex-col gap-3 z-40 w-72\" data-kid=\"2-2-1-5\" data-name=\"kpi overlay cards container\">\n\n<div class=\"glass-panel p-4 rounded-2xl flex items-center justify-between border-l-4 border-blue-600\" data-kid=\"2-2-1-5-1\" data-name=\"active vehicles kpi card\">\n<div data-kid=\"2-2-1-5-1-1\" data-name=\"active vehicles text content\">\n<div class=\"text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1\" data-kid=\"2-2-1-5-1-1-1\" data-name=\"active vehicles title\">Active Vehicles</div>\n<div class=\"text-2xl font-black tabular-nums text-[#0A0F1E]\" data-kid=\"2-2-1-5-1-1-2\" data-name=\"active vehicles number\">121</div>\n</div>\n<div class=\"text-right\" data-kid=\"2-2-1-5-1-2\" data-name=\"active vehicles graph container\">\n<div class=\"text-[10px] font-bold text-green-600 bg-green-50 px-2 py-0.5 rounded-full mb-2\" data-kid=\"2-2-1-5-1-2-1\" data-name=\"active vehicles percentage change\">▲ 8%</div>\n<svg class=\"w-12 h-6 text-blue-500\" data-kid=\"2-2-1-5-1-2-2\" data-name=\"active vehicles sparkline\" viewbox=\"0 0 50 20\"><path d=\"M0 15 L10 12 L20 18 L30 10 L40 14 L50 5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" data-kid=\"7\"></path></svg>\n</div>\n</div>\n\n<div class=\"glass-panel p-4 rounded-2xl flex items-center justify-between ring-2 ring-blue-600/50 shadow-blue-500/10\" data-kid=\"2-2-1-5-2\" data-name=\"active trips kpi card\">\n<div data-kid=\"2-2-1-5-2-1\" data-name=\"active trips text content\">\n<div class=\"text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1\" data-kid=\"2-2-1-5-2-1-1\" data-name=\"active trips title\">Active Trips</div>\n<div class=\"text-2xl font-black tabular-nums text-[#0A0F1E]\" data-kid=\"2-2-1-5-2-1-2\" data-name=\"active trips number\">42</div>\n</div>\n<div class=\"text-right\" data-kid=\"2-2-1-5-2-2\" data-name=\"active trips graph container\">\n<div class=\"text-[10px] font-bold text-green-600 bg-green-50 px-2 py-0.5 rounded-full mb-2\" data-kid=\"2-2-1-5-2-2-1\" data-name=\"active trips percentage change\">▲ 11%</div>\n<svg class=\"w-12 h-6 text-blue-500\" data-kid=\"2-2-1-5-2-2-2\" data-name=\"active trips sparkline\" viewbox=\"0 0 50 20\"><path d=\"M0 18 L10 15 L20 12 L30 8 L40 5 L50 2\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" data-kid=\"8\"></path></svg>\n</div>\n</div>\n\n<div class=\"glass-panel p-4 rounded-2xl flex items-center justify-between\" data-kid=\"2-2-1-5-3\" data-name=\"fleet utilization kpi card\">\n<div data-kid=\"2-2-1-5-3-1\" data-name=\"fleet utilization text content\">\n<div class=\"text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1\" data-kid=\"2-2-1-5-3-1-1\" data-name=\"fleet utilization title\">Utilization</div>\n<div class=\"text-2xl font-black tabular-nums text-[#0A0F1E]\" data-kid=\"2-2-1-5-3-1-2\" data-name=\"fleet utilization percentage\">84%</div>\n</div>\n<div class=\"relative w-10 h-10\" data-kid=\"2-2-1-5-3-2\" data-name=\"fleet utilization chart container\">\n<svg class=\"w-full h-full -rotate-90\" data-kid=\"2-2-1-5-3-2-1\" data-name=\"utilization circular progress ring\" viewbox=\"0 0 36 36\">\n<path d=\"M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831\" fill=\"none\" stroke=\"#E2E8F0\" stroke-width=\"3\" data-kid=\"9\"></path>\n<path d=\"M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831\" fill=\"none\" stroke=\"#2563EB\" stroke-dasharray=\"84, 100\" stroke-width=\"3\" data-kid=\"10\"></path>\n</svg>\n</div>\n</div>\n</div>\n\n<div class=\"absolute top-28 right-6 w-80 z-40\" data-kid=\"2-2-1-6\" data-name=\"trip details floating panel\">\n<div class=\"glass-panel-dark rounded-2xl p-6 text-white border-white/20 shadow-2xl\" data-kid=\"2-2-1-6-1\" data-name=\"trip details glass card\">\n<div class=\"flex items-center justify-between mb-6\" data-kid=\"2-2-1-6-1-1\" data-name=\"trip header section\">\n<span class=\"text-xs font-black uppercase tracking-widest opacity-60\" data-kid=\"2-2-1-6-1-1-1\" data-name=\"trip ID\">TRIP DETAILS · TR-9114</span>\n<span class=\"text-[10px] font-bold bg-amber-500/20 text-amber-400 px-2 py-1 rounded-lg border border-amber-500/30\" data-kid=\"2-2-1-6-1-1-2\" data-name=\"trip status label\">⚠ DELAYED</span>\n</div>\n<div class=\"space-y-6\" data-kid=\"2-2-1-6-1-2\" data-name=\"trip itinerary and info section\">\n<div class=\"flex items-start gap-4\" data-kid=\"2-2-1-6-1-2-1\" data-name=\"origin location row\">\n<div class=\"w-8 h-8 rounded-full bg-blue-500/20 border border-blue-500/30 flex items-center justify-center shrink-0\" data-kid=\"2-2-1-6-1-2-1-1\" data-name=\"origin icon container\">\n<i class=\"ti ti-map-pin text-blue-400\" data-kid=\"2-2-1-6-1-2-1-1-1\" data-name=\"map pin icon\"></i>\n</div>\n<div data-kid=\"2-2-1-6-1-2-1-2\" data-name=\"origin text group\">\n<div class=\"text-[10px] font-bold text-blue-400 uppercase tracking-widest mb-1\" data-kid=\"2-2-1-6-1-2-1-2-1\" data-name=\"origin title\">Origin</div>\n<div class=\"text-sm font-bold\" data-kid=\"2-2-1-6-1-2-1-2-2\" data-name=\"origin name\">Chicago Depot (CHI-3)</div>\n</div>\n</div>\n<div class=\"flex items-start gap-4\" data-kid=\"2-2-1-6-1-2-2\" data-name=\"destination location row\">\n<div class=\"w-8 h-8 rounded-full bg-green-500/20 border border-green-500/30 flex items-center justify-center shrink-0\" data-kid=\"2-2-1-6-1-2-2-1\" data-name=\"destination icon container\">\n<i class=\"ti ti-map-pin-filled text-green-400\" data-kid=\"2-2-1-6-1-2-2-1-1\" data-name=\"filled map pin icon\"></i>\n</div>\n<div data-kid=\"2-2-1-6-1-2-2-2\" data-name=\"destination text group\">\n<div class=\"text-[10px] font-bold text-green-400 uppercase tracking-widest mb-1\" data-kid=\"2-2-1-6-1-2-2-2-1\" data-name=\"destination title\">Destination</div>\n<div class=\"text-sm font-bold\" data-kid=\"2-2-1-6-1-2-2-2-2\" data-name=\"destination name\">Minneapolis Terminal (MSP-2)</div>\n</div>\n</div>\n<div class=\"grid grid-cols-2 gap-6 pt-4 border-t border-white/10\" data-kid=\"2-2-1-6-1-2-3\" data-name=\"trip driver and eta info\">\n<div data-kid=\"2-2-1-6-1-2-3-1\" data-name=\"driver info group\">\n<div class=\"text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1\" data-kid=\"2-2-1-6-1-2-3-1-1\" data-name=\"driver title\">Active Driver</div>\n<div class=\"text-sm font-bold\" data-kid=\"2-2-1-6-1-2-3-1-2\" data-name=\"driver name\">Sarah Davis</div>\n</div>\n<div data-kid=\"2-2-1-6-1-2-3-2\" data-name=\"eta info group\">\n<div class=\"text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1\" data-kid=\"2-2-1-6-1-2-3-2-1\" data-name=\"eta title\">GPS ETA</div>\n<div class=\"text-sm font-bold\" data-kid=\"2-2-1-6-1-2-3-2-2\" data-name=\"eta time value\">⏱ 3.8 Hours</div>\n</div>\n</div>\n</div>\n<button class=\"w-full mt-8 bg-white/10 hover:bg-white/20 border border-white/20 h-10 rounded-xl text-xs font-bold transition-colors\" data-kid=\"2-2-1-6-1-3\" data-name=\"open command terminal button\">\n            Open Command Terminal\n          </button>\n</div>\n</div>\n</div>\n\n<div class=\"flex-1 overflow-y-auto px-6 pt-12 pb-20 relative z-10 -mt-20 scroll-hide\" data-kid=\"2-2-2\" data-name=\"scrollable dashboard grid area\">\n\n<div class=\"glass-panel rounded-2xl px-6 h-16 flex items-center gap-8 mb-8\" data-kid=\"2-2-2-1\" data-name=\"filter tools bar\">\n<div class=\"flex items-center gap-3 text-sm font-bold\" data-kid=\"2-2-2-1-1\" data-name=\"filter label group\">\n<i class=\"ti ti-filter text-blue-600\" data-kid=\"2-2-2-1-1-1\" data-name=\"filter icon\"></i>\n          Filters\n        </div>\n<div class=\"w-px h-6 bg-gray-200\" data-kid=\"2-2-2-1-2\" data-name=\"separator\"></div>\n<div class=\"flex gap-4 overflow-x-auto scroll-hide\" data-kid=\"2-2-2-1-3\" data-name=\"filter options horizontal scroll\">\n<div class=\"px-4 py-2 bg-white/50 border border-gray-200 rounded-xl text-xs font-semibold flex items-center gap-2 cursor-pointer hover:bg-white transition-colors\" data-kid=\"2-2-2-1-3-1\" data-name=\"type filter dropdown\">\n            All Types <i class=\"ti ti-chevron-down text-gray-400\" data-kid=\"2-2-2-1-3-1-1\" data-name=\"chevron icon\"></i>\n</div>\n<div class=\"px-4 py-2 bg-white/50 border border-gray-200 rounded-xl text-xs font-semibold flex items-center gap-2 cursor-pointer hover:bg-white transition-colors\" data-kid=\"2-2-2-1-3-2\" data-name=\"status filter dropdown\">\n            All Statuses <i class=\"ti ti-chevron-down text-gray-400\" data-kid=\"2-2-2-1-3-2-1\" data-name=\"chevron icon\"></i>\n</div>\n<div class=\"px-4 py-2 bg-white/50 border border-gray-200 rounded-xl text-xs font-semibold flex items-center gap-2 cursor-pointer hover:bg-white transition-colors\" data-kid=\"2-2-2-1-3-3\" data-name=\"region filter dropdown\">\n            All Regions <i class=\"ti ti-chevron-down text-gray-400\" data-kid=\"2-2-2-1-3-3-1\" data-name=\"chevron icon\"></i>\n</div>\n</div>\n</div>\n\n<div class=\"grid grid-cols-3 gap-8\" data-kid=\"2-2-2-2\" data-name=\"data grid and charts container\">\n\n<div class=\"col-span-2 glass-panel rounded-3xl overflow-hidden flex flex-col\" data-kid=\"2-2-2-2-1\" data-name=\"operations overview table\">\n<div class=\"p-6 border-b border-gray-100 flex items-center justify-between\" data-kid=\"2-2-2-2-1-1\" data-name=\"table header section\">\n<div data-kid=\"2-2-2-2-1-1-1\" data-name=\"table title section\">\n<h2 class=\"text-lg font-bold\" data-kid=\"2-2-2-2-1-1-1-1\" data-name=\"table main title\">Operations Overview</h2>\n<p class=\"text-xs text-gray-500\" data-kid=\"2-2-2-2-1-1-1-2\" data-name=\"table subtitle\">Real-time status of dispatch activities</p>\n</div>\n<span class=\"text-[10px] font-bold text-blue-600 bg-blue-50 px-3 py-1 rounded-full uppercase tracking-widest\" data-kid=\"2-2-2-2-1-1-2\" data-name=\"active records count badge\">6 Active Records</span>\n</div>\n<table class=\"w-full text-left\" data-kid=\"2-2-2-2-1-2\" data-name=\"operations table body\">\n<thead class=\"bg-gray-50/50 text-[10px] font-bold text-gray-400 uppercase tracking-widest border-b border-gray-100\" data-kid=\"2-2-2-2-1-2-1\" data-name=\"table column titles\">\n<tr data-kid=\"2-2-2-2-1-2-1-1\" data-name=\"header row\">\n<th class=\"px-6 py-4\" data-kid=\"2-2-2-2-1-2-1-1-1\" data-name=\"vehicle column header\">Vehicle</th>\n<th class=\"px-6 py-4\" data-kid=\"2-2-2-2-1-2-1-1-2\" data-name=\"driver column header\">Driver</th>\n<th class=\"px-6 py-4\" data-kid=\"2-2-2-2-1-2-1-1-3\" data-name=\"status column header\">Status</th>\n<th class=\"px-6 py-4 text-right\" data-kid=\"2-2-2-2-1-2-1-1-4\" data-name=\"health column header\">Health</th>\n</tr>\n</thead>\n<tbody class=\"divide-y divide-gray-50\" data-kid=\"2-2-2-2-1-2-2\" data-name=\"table records list\">\n<tr class=\"hover:bg-blue-50/30 transition-colors group\" data-kid=\"2-2-2-2-1-2-2-1\" data-name=\"table record row 1\">\n<td class=\"px-6 py-4\" data-kid=\"2-2-2-2-1-2-2-1-1\" data-name=\"vehicle cell\">\n<div class=\"text-sm font-bold\" data-kid=\"2-2-2-2-1-2-2-1-1-1\" data-name=\"vehicle name\">Volvo VNL 860 <span class=\"text-blue-600 font-mono text-xs\" data-kid=\"2-2-2-2-1-2-2-1-1-1-1\" data-name=\"vehicle ID\">#TRK-892</span></div>\n<div class=\"text-[10px] text-gray-400 uppercase\" data-kid=\"2-2-2-2-1-2-2-1-1-2\" data-name=\"vehicle type\">Semi-Truck</div>\n</td>\n<td class=\"px-6 py-4 flex items-center gap-3\" data-kid=\"2-2-2-2-1-2-2-1-2\" data-name=\"driver cell\">\n<div class=\"w-8 h-8 rounded-lg bg-blue-100 text-blue-600 flex items-center justify-center font-bold text-xs\" data-kid=\"2-2-2-2-1-2-2-1-2-1\" data-name=\"driver initials\">RJ</div>\n<div class=\"text-sm font-bold\" data-kid=\"2-2-2-2-1-2-2-1-2-2\" data-name=\"driver name\">Robert Johnson</div>\n</td>\n<td class=\"px-6 py-4\" data-kid=\"2-2-2-2-1-2-2-1-3\" data-name=\