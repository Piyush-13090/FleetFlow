      "html": "<link data-kid=\"1\" data-name=\"web font stylesheet link\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" rel=\"stylesheet\">\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap');\n  \n  .glass-panel {\n    background: rgba(255, 255, 255, 0.75);\n    backdrop-filter: blur(16px) saturate(120%);\n    -webkit-backdrop-filter: blur(16px) saturate(120%);\n    border: 1px solid rgba(255, 255, 255, 0.4);\n  }\n\n  .input-glow:focus {\n    outline: none;\n    border-color: #2563EB;\n    box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.15);\n  }\n\n  .ripple-btn {\n    position: relative;\n    overflow: hidden;\n    transition: all 0.3s ease;\n  }\n  .ripple-btn:hover {\n    transform: translateY(-2px);\n    box-shadow: 0 10px 20px -10px rgba(37, 99, 235, 0.5);\n  }\n  \n  .animate-float {\n    animation: float 6s ease-in-out infinite;\n  }\n\n  @keyframes float {\n    0%, 100% { transform: translateY(0px); }\n    50% { transform: translateY(-15px); }\n  }\n\n  @keyframes marquee {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n\n  .dark-map-section {\n    background: #0F172A;\n    background-image: radial-gradient(circle at 2px 2px, rgba(59, 130, 246, 0.1) 1px, transparent 0);\n    background-size: 32px 32px;\n  }\n\n  .blob-purple { background: #8B5CF6; filter: blur(120px); opacity: 0.15; }\n  .blob-emerald { background: #10B981; filter: blur(120px); opacity: 0.15; }\n</style>\n<div class=\"relative w-full bg-[#F8FAFC] font-['Outfit'] text-[#0F172A] overflow-hidden\" data-kid=\"2\" data-name=\"main page container\">\n\n<div class=\"absolute top-0 left-0 w-[600px] h-[600px] blob-purple rounded-full -translate-x-1/2 -translate-y-1/2\" data-kid=\"2-1\" data-name=\"decorative purple background blob\"></div>\n<div class=\"absolute top-[800px] right-0 w-[700px] h-[700px] blob-emerald rounded-full translate-x-1/3\" data-kid=\"2-2\" data-name=\"decorative emerald background blob\"></div>\n\n<nav class=\"sticky top-0 z-50 px-8 py-6\" data-kid=\"2-3\" data-name=\"sticky navigation bar\">\n<div class=\"max-w-7xl mx-auto glass-panel rounded-full h-20 px-8 flex items-center justify-between shadow-xl\" data-kid=\"2-3-1\" data-name=\"glass navigation container\">\n<div class=\"flex items-center gap-3\" data-kid=\"2-3-1-1\" data-name=\"brand logo area\">\n<div class=\"w-10 h-10 bg-blue-600 rounded-xl flex items-center justify-center text-white\" data-kid=\"2-3-1-1-1\" data-name=\"brand logo icon container\">\n<i class=\"ti ti-truck text-2xl\" data-kid=\"2-3-1-1-1-1\" data-name=\"truck icon\"></i>\n</div>\n<span class=\"text-2xl font-black tracking-tight\" data-kid=\"2-3-1-1-2\" data-name=\"brand text\">Transit<span class=\"text-blue-600\" data-kid=\"2-3-1-1-2-1\" data-name=\"brand name suffix\">Ops</span></span>\n</div>\n<div class=\"hidden md:flex items-center gap-10\" data-kid=\"2-3-1-2\" data-name=\"navigation links container\">\n<a class=\"text-sm font-bold uppercase tracking-widest text-gray-500 hover:text-blue-600 transition-colors\" data-kid=\"2-3-1-2-1\" data-name=\"fleet navigation link\" href=\"#\">Fleet</a>\n<a class=\"text-sm font-bold uppercase tracking-widest text-gray-500 hover:text-blue-600 transition-colors\" data-kid=\"2-3-1-2-2\" data-name=\"drivers navigation link\" href=\"#\">Drivers</a>\n<a class=\"text-sm font-bold uppercase tracking-widest text-gray-500 hover:text-blue-600 transition-colors\" data-kid=\"2-3-1-2-3\" data-name=\"safety navigation link\" href=\"#\">Safety</a>\n<a class=\"text-sm font-bold uppercase tracking-widest text-gray-500 hover:text-blue-600 transition-colors\" data-kid=\"2-3-1-2-4\" data-name=\"enterprise navigation link\" href=\"#\">Enterprise</a>\n</div>\n<button class=\"ripple-btn bg-blue-600 text-white px-8 py-3 rounded-full text-sm font-bold\" data-kid=\"2-3-1-3\" data-name=\"request demo call-to-action button\">Request Demo</button>\n</div>\n</nav>\n\n<section class=\"relative px-8 pt-20 pb-40 max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-20 items-center\" data-kid=\"2-4\" data-name=\"hero section\">\n<div class=\"z-10\" data-kid=\"2-4-1\" data-name=\"hero content area\">\n<div class=\"inline-block px-4 py-1.5 bg-blue-50 text-blue-600 rounded-full text-xs font-bold uppercase tracking-widest mb-6\" data-kid=\"2-4-1-1\" data-name=\"hero badge label\">Next-Gen Logistics</div>\n<h1 class=\"text-7xl font-extrabold leading-[1.1] mb-8\" data-kid=\"2-4-1-2\" data-name=\"hero main headline\">Next-Gen Logistics <span class=\"text-blue-600\" data-kid=\"2-4-1-2-1\" data-name=\"hero headline emphasized text\">Intelligence.</span></h1>\n<p class=\"text-xl text-gray-500 mb-10 leading-relaxed max-w-lg\" data-kid=\"2-4-1-3\" data-name=\"hero description text\">Command your entire transport operation from a single, high-fidelity interface. Real-time tracking, AI-driven safety, and unified fleet management.</p>\n<div class=\"flex gap-4 max-w-md\" data-kid=\"2-4-1-4\" data-name=\"hero email signup input group\">\n<input class=\"flex-1 h-14 bg-white border border-gray-200 rounded-2xl px-6 text-sm input-glow shadow-sm\" data-kid=\"2-4-1-4-1\" data-name=\"email signup input field\" placeholder=\"Enter your email\" type=\"email\">\n<button class=\"ripple-btn bg-[#0F172A] text-white px-8 py-4 rounded-2xl text-sm font-bold whitespace-nowrap\" data-kid=\"2-4-1-4-2\" data-name=\"signup call-to-action button\">Get Started</button>\n</div>\n</div>\n<div class=\"relative h-[600px]\" data-kid=\"2-4-2\" data-name=\"hero visual container\">\n\n<div class=\"absolute top-10 right-0 w-[320px] glass-panel rounded-3xl p-6 shadow-2xl z-30 animate-float\" data-kid=\"2-4-2-1\" data-name=\"floating glass stat card\">\n<div class=\"flex items-center justify-between mb-4\" data-kid=\"2-4-2-1-1\" data-name=\"stat card header\">\n<span class=\"text-[10px] font-black uppercase tracking-widest text-gray-400\" data-kid=\"2-4-2-1-1-1\" data-name=\"stat card title\">Fuel Efficiency</span>\n<i class=\"ti ti-bolt text-amber-500\" data-kid=\"2-4-2-1-1-2\" data-name=\"lightning bolt icon\"></i>\n</div>\n<div class=\"text-3xl font-black mb-2\" data-kid=\"2-4-2-1-2\" data-name=\"stat value text\">18.4 <span class=\"text-sm font-medium\" data-kid=\"2-4-2-1-2-1\" data-name=\"stat unit label\">km/L</span></div>\n<div class=\"w-full bg-gray-100 h-1.5 rounded-full overflow-hidden\" data-kid=\"2-4-2-1-3\" data-name=\"progress bar container\">\n<div class=\"bg-amber-500 h-full w-[72%]\" data-kid=\"2-4-2-1-3-1\" data-name=\"progress bar indicator\"></div>\n</div>\n</div>\n<div class=\"absolute top-40 -left-10 w-[400px] h-[300px] glass-panel rounded-[2rem] overflow-hidden shadow-2xl z-20 dark-map-section p-1\" data-kid=\"2-4-2-2\" data-name=\"glass map overlay container\">\n<div class=\"w-full h-full rounded-[1.8rem] overflow-hidden opacity-60\" data-kid=\"2-4-2-2-1\" data-name=\"map chart container\">\n<svg class=\"w-full h-full\" data-kid=\"2-4-2-2-1-1\" data-name=\"route chart svg\" viewbox=\"0 0 400 300\">\n<path d=\"M 50 250 Q 200 50 350 250\" fill=\"none\" stroke=\"#3B82F6\" stroke-dasharray=\"8 4\" stroke-width=\"2\" data-kid=\"3\"></path>\n<circle cx=\"50\" cy=\"250\" fill=\"#3B82F6\" r=\"4\" data-kid=\"4\"></circle>\n<circle cx=\"350\" cy=\"250\" fill=\"#3B82F6\" r=\"4\" data-kid=\"5\"></circle>\n</svg>\n</div>\n</div>\n<div class=\"absolute bottom-10 right-10 w-[280px] glass-panel rounded-3xl p-5 shadow-2xl z-10\" data-kid=\"2-4-2-3\" data-name=\"driver status glass card\">\n<div class=\"flex items-center gap-4\" data-kid=\"2-4-2-3-1\" data-name=\"driver profile group\">\n<img class=\"w-12 h-12 rounded-2xl border-2 border-white shadow-sm\" data-kid=\"2-4-2-3-1-1\" data-name=\"driver avatar image\" src=\"https://i.pravatar.cc/100?u=sarah\">\n<div data-kid=\"2-4-2-3-1-2\" data-name=\"driver status details\">\n<div class=\"text-sm font-bold\" data-kid=\"2-4-2-3-1-2-1\" data-name=\"driver name\">Sarah Chen</div>\n<div class=\"text-[10px] font-bold text-green-600 uppercase\" data-kid=\"2-4-2-3-1-2-2\" data-name=\"driver status label\">Active • Unit-12B</div>\n</div>\n</div>\n</div>\n</div>\n</section>\n\n<div class=\"h-12 bg-blue-600 flex items-center overflow-hidden\" data-kid=\"2-5\" data-name=\"ticker tape marquee section\">\n<div class=\"flex items-center gap-16 whitespace-nowrap animate-[marquee_40s_linear_infinite] px-8\" data-kid=\"2-5-1\" data-name=\"marquee content wrapper\">\n<div class=\"flex items-center gap-3 text-white text-xs font-bold uppercase tracking-widest\" data-kid=\"2-5-1-1\" data-name=\"marquee item alert\">\n<span class=\"bg-red-500 px-2 py-0.5 rounded\" data-kid=\"2-5-1-1-1\" data-name=\"alert badge\">Alert</span> Unit 42: Hard braking detected Sector 7G\n      </div>\n<div class=\"flex items-center gap-3 text-white text-xs font-bold uppercase tracking-widest\" data-kid=\"2-5-1-2\" data-name=\"marquee item update\">\n<span class=\"bg-blue-400 px-2 py-0.5 rounded\" data-kid=\"2-5-1-2-1\" data-name=\"update badge\">Update</span> Unit 18: Rerouted due to heavy traffic on I-95\n      </div>\n<div class=\"flex items-center gap-3 text-white text-xs font-bold uppercase tracking-widest\" data-kid=\"2-5-1-3\" data-name=\"marquee item notice\">\n<span class=\"bg-amber-400 px-2 py-0.5 rounded text-amber-900\" data-kid=\"2-5-1-3-1\" data-name=\"notice badge\">Notice</span> Alex (Driver): Dispatching trip to Jersey City\n      </div>\n\n<div class=\"flex items-center gap-3 text-white text-xs font-bold uppercase tracking-widest\" data-kid=\"2-5-1-4\" data-name=\"marquee item duplicate alert\">\n<span class=\"bg-red-500 px-2 py-0.5 rounded\" data-kid=\"2-5-1-4-1\" data-name=\"duplicate alert badge\">Alert</span> Unit 42: Hard braking detected Sector 7G\n      </div>\n</div>\n</div>\n\n<section class=\"py-32 px-8 max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-20 items-center\" data-kid=\"2-6\" data-name=\"operations features section\">\n<div data-kid=\"2-6-1\" data-name=\"operations content area\">\n<h2 class=\"text-5xl font-extrabold mb-8 leading-tight\" data-kid=\"2-6-1-1\" data-name=\"features headline\">Orchestrate Fleet Operations <span class=\"text-blue-600\" data-kid=\"2-6-1-1-1\" data-name=\"features headline suffix\">Live.</span></h2>\n<p class=\"text-lg text-gray-500 mb-10\" data-kid=\"2-6-1-2\" data-name=\"features description text\">Track every vehicle and trip in real-time. Our intelligent orchestration engine ensures maximum fleet utilization and on-time deliveries with zero manual intervention.</p>\n<div class=\"grid grid-cols-2 gap-8\" data-kid=\"2-6-1-3\" data-name=\"features metrics grid\">\n<div data-kid=\"2-6-1-3-1\" data-name=\"trips metric card\">\n<div class=\"text-4xl font-black text-blue-600 mb-2\" data-kid=\"2-6-1-3-1-1\" data-name=\"trips metric value\">1,204</div>\n<div class=\"text-[10px] font-black uppercase tracking-widest text-gray-400\" data-kid=\"2-6-1-3-1-2\" data-name=\"trips metric label\">Active Trips Today</div>\n</div>\n<div data-kid=\"2-6-1-3-2\" data-name=\"utilization metric card\">\n<div class=\"text-4xl font-black text-blue-600 mb-2\" data-kid=\"2-6-1-3-2-1\" data-name=\"utilization metric value\">88%</div>\n<div class=\"text-[10px] font-black uppercase tracking-widest text-gray-400\" data-kid=\"2-6-1-3-2-2\" data-name=\"utilization metric label\">Fleet Utilization</div>\n</div>\n</div>\n</div>\n<div class=\"flex justify-center\" data-kid=\"2-6-2\" data-name=\"operations visual container\">\n<div class=\"relative w-[450px] h-[450px] flex items-center justify-center\" data-kid=\"2-6-2-1\" data-name=\"operations decorative visualization\">\n<div class=\"absolute inset-0 glass-panel rounded-[3rem] shadow-inner opacity-50\" data-kid=\"2-6-2-1-1\" data-name=\"decorative visual background\"></div>\n<div class=\"w-64 h-64 flex items-center justify-center border-[20px] border-blue-100 rounded-full relative z-10 bg-white\" data-kid=\"2-6-2-1-2\" data-name=\"central metric gauge\">\n<img class=\"w-32 h-32 absolute opacity-10\" data-kid=\"2-6-2-1-2-1\" data-name=\"gauge icon\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/radial-balance.svg\" style=\"color: #3B82F6;\">\n<div class=\"text-center z-10\" data-kid=\"2-6-2-1-2-2\" data-name=\"gauge central text\">\n<div class=\"text-6xl font-black text-blue-600\" data-kid=\"2-6-2-1-2-2-1\" data-name=\"gauge value\">1.2K</div>\n<div class=\"text-[10px] font-bold uppercase tracking-widest text-blue-400\" data-kid=\"2-6-2-1-2-2-2\" data-name=\"gauge label\">Active Units</div>\n</div>\n</div>\n<img alt=\"Electric Van\" class=\"absolute -bottom-10 -right-20 w-[420px] animate-float drop-shadow-2xl z-20\" data-kid=\"2-6-2-1-3\" data-name=\"electric van graphic\" src=\"https://images.unsplash.com/photo-1732193933813-4da17265a36c?auto=format&amp;w=800&amp;q=80&amp;fit=crop\">\n</div>\n</div>\n</section>\n\n<section class=\"py-32 bg-white/30\" data-kid=\"2-7\" data-name=\"driver management section\">\n<div class=\"max-w-7xl mx-auto px-8 grid grid-cols-1 lg:grid-cols-2 gap-20 items-center\" data-kid=\"2-7-1\" data-name=\"driver management container\">\n<div class=\"order-2 lg:order-1\" data-kid=\"2-7-1-1\" data-name=\"driver management visual panel\">\n<div class=\"glass-panel rounded-[2.5rem] shadow-2xl overflow-hidden p-2\" data-kid=\"2-7-1-1-1\" data-name=\"active drivers board\">\n<div class=\"bg-[#F8FAFC]/50 rounded-[2.2rem] p-8\" data-kid=\"2-7-1-1-1-1\" data-name=\"board header area\">\n<div class=\"flex items-center justify-between mb-8\" data-kid=\"2-7-1-1-1-1-1\" data-name=\"board title\">\n<h3 class=\"font-bold text-xl\" data-kid=\"2-7-1-1-1-1-1-1\">Active Drivers</h3>\n<span class=\"text-xs font-bold text-blue-600 bg-blue-50 px-3 py-1 rounded-full uppercase\" data-kid=\"2-7-1-1-1-1-1-2\">24 Online</span>\n</div>\n<div class=\"space-y-4\" data-kid=\"2-7-1-1-1-1-2\" data-name=\"online status count badge\">\n<div class=\"flex items-center gap-4 p-5 glass-panel bg-white/80 rounded-2xl border-white\" data-kid=\"2-7-1-1-1-1-2-1\">\n<img class=\"w-10 h-10\" data-kid=\"2-7-1-1-1-1-2-1-1\" src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/oncoming-automobile.svg\">\n<div class=\"flex-1\" data-kid=\"2-7-1-1-1-1-2-1-2\">\n<div class=\"font-bold\" data-kid=\"2-7-1-1-1-1-2-1-2-1\">Marco Rossi</div>\n<div class=\"text-[10px] text-gray-400 font-bold uppercase tracking-wider\" data-kid=\"2-7-1-1-1-1-2-1-2-2\">Unit-77A • Route A1</div>\n</div>\n<div class=\"bg-green-100 text-green-600 px-3 py-1 rounded-full text-[10px] font-black uppercase\" data-kid=\"2-7-1-1-1-1-2-1-3\">Active</div>\n</div>\n<div class=\"flex items-center gap-4 p-5 glass-panel bg-white/80 rounded-2xl border-white\" data-kid=\"2-7-1-1-1-1-2-2\">\n<img class=\"w-10 h-10\" data-kid=\"2-7-1-1-1-1-2-2-1\" src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/oncoming-automobile.svg\">\n<div class=\"flex-1\" data-kid=\"2-7-1-1-1-1-2-2-2\">\n<div class=\"font-bold\" data-kid=\"2-7-1-1-1-1-2-2-2-1\">Sarah Chen</div>\n<div class=\"text-[10px] text-gray-400 font-bold uppercase tracking-wider\" data-kid=\"2-7-1-1-1-1-2-2-2-2\">Unit-12B • Route C4</div>\n</div>\n<div class=\"bg-green-100 text-green-600 px-3 py-1 rounded-full text-[10px] font-black uppercase\" data-kid=\"2-7-1-1-1-1-2-2-3\">Active</div>\n</div>\n<div class=\"flex items-center gap-4 p-5 glass-panel bg-white/20 rounded-2xl border-white opacity-50\" data-kid=\"2-7-1-1-1-1-2-3\">\n<img class=\"w-10 h-10\" data-kid=\"2-7-1-1-1-1-2-3-1\" src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/sleeping-face.svg\">\n<div class=\"flex-1\" data-kid=\"2-7-1-1-1-1-2-3-2\">\n<div class=\"font-bold\" data-kid=\"2-7-1-1-1-1-2-3-2-1\">Dave Miller</div>\n<div class=\"text-[10px] text-gray-400 font-bold uppercase tracking-wider\" data-kid=\"2-7-1-1-1-1-2-3-2-2\">Standby</div>\n</div>\n<div class=\"bg-gray-100 text-gray-500 px-3 py-1 rounded-full text-[10px] font-black uppercase\" data-kid=\"2-7-1-1-1-1-2-3-3\">Resting</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"order-1 lg:order-2\" data-kid=\"2-7-1-2\" data-name=\"driver management content area\">\n<h2 class=\"text-5xl font-extrabold mb-8 leading-tight\" data-kid=\"2-7-1-2-1\" data-name=\"driver section headline\">Empower Your <span class=\"text-blue-600\" data-kid=\"2-7-1-2-1-1\" data-name=\"headline emphasized text\">Drivers.</span></h2>\n<p class=\"text-lg text-gray-500 mb-10 leading-relaxed\" data-kid=\"2-7-1-2-2\" data-name=\"driver section description\">Safety first, efficiency always. Our driver management suite provides real-time coaching, safety scoring, and automatic trip assignments that maximize driver satisfaction and safety.</p>\n<div class=\"flex items-center gap-4 p-6 glass-panel rounded-2xl border-blue-100 max-w-sm\" data-kid=\"2-7-1-2-3\" data-name=\"safety score widget\">\n<i class=\"ti ti-shield-check text-3xl text-blue-600\" data-kid=\"2-7-1-2-3-1\" data-name=\"shield check icon\"></i>\n<div data-kid=\"2-7-1-2-3-2\" data-name=\"safety score text group\">\n<div class=\"text-2xl font-black\" data-kid=\"2-7-1-2-3-2-1\" data-name=\"safety score value\">94.2</div>\n<div class=\"text-[10px] font-black uppercase tracking-widest text-gray-400\" data-kid=\"2-7-1-2-3-2-2\" data-name=\"safety score label\">Avg Safety Score</div>\n</div>\n</div>\n</div>\n</div>\n</section>\n\n<section class=\"relative py-40 dark-map-section overflow-hidden\" data-kid=\"2-8\" data-name=\"immersive map section\">\n<div class=\"absolute inset-0 opacity-40\" data-kid=\"2-8-1\" data-name=\"map animation container\">\n<svg class=\"w-full h-full\" data-kid=\"2-8-1-1\" data-name=\"animated route svg\" viewbox=\"0 0 1440 800\">\n<path class=\"animate-[dash_20s_linear_infinite]\" d=\"M -100 400 Q 300 100 720 400 T 1540 400\" fill=\"none\" stroke=\"#3B82F6\" stroke-dasharray=\"12 6\" stroke-width=\"3\" data-kid=\"6\"></path>\n<path d=\"M -100 500 Q 500 200 720 500 T 1540 500\" fill=\"none\" opacity=\"0.5\" stroke=\"#10B981\" stroke-dasharray=\"8 4\" stroke-width=\"2\" data-kid=\"7\"></path>\n</svg>\n</div>\n<div class=\"relative z-10 max-w-7xl mx-auto px-8\" data-kid=\"2-8-2\" data-name=\"map section content container\">\n<div class=\"grid grid-cols-1 lg:grid-cols-2 gap-20 items-end\" data-kid=\"2-8-2-1\" data-name=\"map content layout grid\">\n<div data-kid=\"2-8-2-1-1\" data-name=\"map section headline area\">\n<h2 class=\"text-6xl font-black text-white mb-8\" data-kid=\"2-8-2-1-1-1\" data-name=\"map main headline\">Global Operations, <br data-kid=\"2-8-2-1-1-1-1\" data-name=\"headline line break\"><span class=\"text-blue-500 text-7xl\" data-kid=\"2-8-2-1-1-1-2\" data-name=\"headline emphasized text\">Unified.</span></h2>\n<p class=\"text-xl text-gray-400 leading-relaxed max-w-md\" data-kid=\"2-8-2-1-1-2\" data-name=\"map section description\">Our network topology allows for seamless cross-border logistics tracking and real-time operational pivots.</p>\n</div>\n<div class=\"flex gap-12 justify-end\" data-kid=\"2-8-2-1-2\" data-name=\"map performance stats container\">\n<div class=\"text-center\" data-kid=\"2-8-2-1-2-1\" data-name=\"delivery time stat group\">\n<div class=\"text-7xl font-black text-white mb-2 tracking-tighter\" data-kid=\"2-8-2-1-2-1-1\" data-name=\"delivery time value\">42<span class=\"text-blue-500 text-3xl ml-2\" data-kid=\"2-8-2-1-2-1-1-1\" data-name=\"delivery time unit\">m</span></div>\n<div class=\"text-[10px] font-black uppercase tracking-widest text-blue-400\" data-kid=\"2-8-2-1-2-1-2\" data-name=\"delivery time label\">Avg Delivery Time</div>\n</div>\n<div class=\"text-center\" data-kid=\"2-8-2-1-2-2\" data-name=\"sla success stat group\">\n<div class=\"text-7xl font-black text-white mb-2 tracking-tighter\" data-kid=\"2-8-2-1-2-2-1\" data-name=\"sla success value\">99.8<span class=\"text-emerald-500 text-3xl ml-2\" data-kid=\"2-8-2-1-2-2-1-1\" data-name=\"sla success unit\">%</span></div>\n<div class=\"text-[10px] font-black uppercase tracking-widest text-emerald-400\" data-kid=\"2-8-2-1-2-2-2\" data-name=\"sla success label\">SLA Success Rate</div>\n</div>\n</div>\n</div>\n</div>\n</section>\n\n<footer class=\"pt-20 px-8 pb-10\" data-kid=\"2-9\" data-name=\"page footer\">\n<div class=\"max-w-7xl mx-auto glass-panel rounded-t-[3rem] p-16 shadow-2xl border-b-0\" data-kid=\"2-9-1\" data-name=\"footer glass panel container\">\n<div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-20\" data-kid=\"2-9-1-1\" data-name=\"footer content grid\">\n<div class=\"col-span-1 lg:col-span-1\" data-kid=\"2-9-1-1-1\" data-name=\"footer brand section\">\n<div class=\"flex items-center gap-3 mb-8\" data-kid=\"2-9-1-1-1-1\" data-name=\"footer logo group\">\n<div class=\"w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center text-white\" data-kid=\"2-9-1-1-1-1-1\" data-name=\"footer truck icon\">\n<i class=\"ti ti-truck text-lg\" data-kid=\"2-9-1-1-1-1-1-1\"></i>\n</div>\n<span class=\"text-xl font-black tracking-tight\" data-kid=\"2-9-1-1-1-1-2\" data-name=\"footer brand name\">Transit<span class=\"text-blue-600\" data-kid=\"2-9-1-1-1-1-2-1\" data-name=\"footer brand suffix\">Ops</span></span>\n</div>\n<p class=\"text-sm text-gray-500 leading-relaxed\" data-kid=\"2-9-1-1-1-2\" data-name=\"footer brand description\">The smarter way to manage your transport lifecycle from registration to ROI.</p>\n</div>\n<div data-kid=\"2-9-1-1-2\" data-name=\"platform links column\">\n<h4 class=\"text-[10px] font-black uppercase tracking-widest text-gray-400 mb-8\" data-kid=\"2-9-1-1-2-1\" data-name=\"platform links title\">Platform</h4>\n<ul class=\"space-y-4 text-sm font-bold text-gray-600\" data-kid=\"2-9-1-1-2-2\" data-name=\"platform links list\">\n<li data-kid=\"2-9-1-1-2-2-1\" data-name=\"link vehicle registry\"><a class=\"hover:text-blue-600 transition-colors\" data-kid=\"2-9-1-1-2-2-1-1\" data-name=\"link vehicle registry anchor\" href=\"#\">Vehicle Registry</a></li>\n<li data-kid=\"2-9-1-1-2-2-2\" data-name=\"link driver suite\"><a class=\"hover:text-blue-600 transition-colors\" data-kid=\"2-9-1-1-2-2-2-1\" data-name=\"link driver suite anchor\" href=\"#\">Driver Suite</a></li>\n<li data-kid=\"2-9-1-1-2-2-3\" data-name=\"link trip dispatch\"><a class=\"hover:text-blue-600 transition-colors\" data-kid=\"2-9-1-1-2-2-3-1\" data-name=\"link trip dispatch anchor\" href=\"#\">Trip Dispatch</a></li>\n<li data-kid=\"2-9-1-1-2-2-4\" data-name=\"link maintenance\"><a class=\"hover:text-blue-600 transition-colors\" data-kid=\"2-9-1-1-2-2-4-1\" data-name=\"link maintenance anchor\" href=\"#\">Maintenance</a></li>\n</ul>\n</div>\n<div data-kid=\"2-9-1-1-3\" data-name=\"company links column\">\n<h4 class=\"text-[10px] font-black uppercase tracking-widest text-gray-400 mb-8\" data-kid=\"2-9-1-1-3-1\" data-name=\"company links title\">Company</h4>\n<ul class=\"space-y-4 text-sm font-bold text-gray-600\" data-kid=\"2-9-1-1-3-2\" data-name=\"company links list\">\n<li data-kid=\"2-9-1-1-3-2-1\" data-name=\"link about us\"><a class=\"hover:text-blue-600 transition-colors\" data-kid=\"2-9-1-1-3-2-1-1\" data-name=\"link about us anchor\" href=\"#\">About Us</a></li>\n<li data-kid=\"2-9-1-1-3-2-2\" data-name=\"link customers\"><a class=\"hover:text-blue-600 transition-colors\" data-kid=\"2-9-1-1-3-2-2-1\" data-name=\"link customers anchor\" href=\"#\">Customers</a></li>\n<li data-kid=\"2-9-1-1-3-2-3\" data-name=\"link safety standards\"><a class=\"hover:text-blue-600 transition-colors\" data-kid=\"2-9-1-1-3-2-3-1\" data-name=\"link safety standards anchor\" href=\"#\">Safety Standards</a></li>\n<li data-kid=\"2-9-1-1-3-2-4\" data-name=\"link legal\"><a class=\"hover:text-blue-600 transition-colors\" data-kid=\"2-9-1-1-3-2-4-1\" data-name=\"link legal anchor\" href=\"#\">Legal</a></li>\n</ul>\n</div>\n<div data-kid=\"2-9-1-1-4\" data-name=\"join us section\">\n<h4 class=\"text-[10px] font-black uppercase tracking-widest text-gray-400 mb-8\" data-kid=\"2-9-1-1-4-1\" data-name=\"join us title\">Join Us</h4>\n<p class=\"text-xs text-gray-400 mb-6 font-medium\" data-kid=\"2-9-1-1-4-2\" data-name=\"join us description\">Get the latest insights on fleet optimization delivered weekly.</p>\n<div class=\"relative\" data-kid=\"2-9-1-1-4-3\" data-name=\"newsletter input group\">\n<input class=\"w-full bg-white border border-gray-100 h-12 rounded-xl px-4 text-xs font-bold input-glow\" data-kid=\"2-9-1-1-4-3-1\" data-name=\"newsletter input field\" placeholder=\"Your email\" type=\"text\">\n<button class=\"absolute right-1 top-1 h-10 w-10 bg-blue-600 rounded-lg text-white flex items-center justify-center\" data-kid=\"2-9-1-1-4-3-2\" data-name=\"newsletter submit button\">\n<i class=\"ti ti-arrow-right\" data-kid=\"2-9-1-1-4-3-2-1\" data-name=\"newsletter arrow icon\"></i>\n</button>\n</div>\n</div>\n</div>\n<div class=\"pt-10 border-t border-gray-100 flex flex-col md:flex-row justify-between items-center gap-6\" data-kid=\"2-9-1-2\" data-name=\"footer copyright bar\">\n<div class=\"text-[10px] font-black uppercase tracking-widest text-gray-400\" data-kid=\"2-9-1-2-1\" data-name=\"copyright text\">© 2026 TransitOps Operations Platform. All rights reserved.</div>\n<div class=\"flex gap-8\" data-kid=\"2-9-1-2-2\" data-name=\"footer social icons\">\n<i class=\"ti ti-brand-twitter text-gray-400 hover:text-blue-600 cursor-pointer transition-colors\" data-kid=\"2-9-1-2-2-1\" data-name=\"twitter icon\"></i>\n<i class=\"ti ti-brand-linkedin text-gray-400 hover:text-blue-600 cursor-pointer transition-colors\" data-kid=\"2-9-1-2-2-2\" data-name=\"linkedin icon\"></i>\n<i class=\"ti ti-brand-github text-gray-400 hover:text-blue-600 cursor-pointer transition-colors\" data-kid=\"2-9-1-2-2-3\" data-name=\"github icon\"></i>\n</div>\n</div>\n</div>\n</footer>\n</div>\n<style data-kid=\"8\">\n  @keyframes dash {\n    to { stroke-dashoffset: -100; }\n  }\n</style>",
