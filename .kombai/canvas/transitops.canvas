      "html": "<link data-kid=\"1\" data-name=\"google fonts stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&amp;display=swap\" rel=\"stylesheet\">\n<link data-kid=\"2\" data-name=\"tabler icons stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" rel=\"stylesheet\">\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\" data-kid=\"0\"></script>\n<style data-kid=\"5\">\n  body {\n    margin: 0;\n    padding: 0;\n    font-family: 'Outfit', sans-serif;\n    background-color: #FBFCFD;\n    color: #1E293B;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .tabular-nums {\n    font-variant-numeric: tabular-nums;\n  }\n\n  .glass-panel {\n    background: rgba(255, 255, 255, 0.8);\n    backdrop-filter: blur(12px);\n    border: 1px solid #E2E8F0;\n  }\n\n  .card-shadow {\n    box-shadow: 0 1px 2px rgba(16, 24, 40, 0.04), 0 1px 3px rgba(16, 24, 40, 0.06);\n  }\n\n  .status-pill {\n    display: inline-flex;\n    align-items: center;\n    gap: 6px;\n    padding: 2px 10px;\n    border-radius: 9999px;\n    font-size: 12px;\n    font-weight: 600;\n  }\n\n  .status-dot {\n    width: 6px;\n    height: 6px;\n    border-radius: 50%;\n  }\n\n  .icon-tile {\n    width: 40px;\n    height: 40px;\n    border-radius: 10px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 20px;\n  }\n\n  @keyframes spin {\n    from { transform: rotate(0deg); }\n    to { transform: rotate(360deg); }\n  }\n  .animate-spin-slow {\n    animation: spin 3s linear infinite;\n  }\n\n  /* Custom Scrollbar */\n  ::-webkit-scrollbar {\n    width: 6px;\n    height: 6px;\n  }\n  ::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  ::-webkit-scrollbar-thumb {\n    background: #E2E8F0;\n    border-radius: 10px;\n  }\n  ::-webkit-scrollbar-thumb:hover {\n    background: #CBD5E1;\n  }\n</style>\n<div class=\"min-h-screen pb-20\" data-kid=\"3\" data-name=\"main page content container\">\n\n<nav class=\"sticky top-0 z-50 h-16 bg-white border-b border-[#E2E8F0] px-6 flex items-center justify-between shadow-sm\" data-kid=\"3-1\" data-name=\"top navigation bar\">\n<div class=\"flex items-center gap-6 flex-1\" data-kid=\"3-1-1\" data-name=\"navigation left side container\">\n<div class=\"flex items-center gap-2 bg-[#F1F5F9] px-3 py-1.5 rounded-full border border-[#E2E8F0] cursor-pointer hover:bg-[#E2E8F0] transition-colors\" data-kid=\"3-1-1-1\" data-name=\"fleet hub selector\">\n<i class=\"ti ti-world text-[#2563EB]\" data-kid=\"3-1-1-1-1\" data-name=\"world icon\"></i>\n<span class=\"text-sm font-bold\" data-kid=\"3-1-1-1-2\" data-name=\"fleet hub label\">NE Fleet Hub</span>\n<i class=\"ti ti-chevron-down text-[#94A3B8]\" data-kid=\"3-1-1-1-3\" data-name=\"chevron down icon\"></i>\n</div>\n<div class=\"relative w-full max-w-xl\" data-kid=\"3-1-1-2\" data-name=\"search input container\">\n<i class=\"ti ti-search absolute left-4 top-1/2 -translate-y-1/2 text-[#94A3B8]\" data-kid=\"3-1-1-2-1\" data-name=\"search icon\"></i>\n<input class=\"w-full h-10 bg-[#F8FAFC] border border-[#E2E8F0] rounded-full pl-11 pr-4 text-sm focus:outline-none focus:ring-2 focus:ring-[#2563EB]/10 focus:border-[#2563EB] transition-all\" data-kid=\"3-1-1-2-2\" data-name=\"search input field\" placeholder=\"Search vehicles, routes, drivers, cargos...\" type=\"text\">\n</div>\n</div>\n<div class=\"flex items-center gap-4\" data-kid=\"3-1-2\" data-name=\"navigation right side container\">\n<div class=\"hidden lg:flex items-center gap-2 px-4 py-1.5 bg-[#F8FAFC] rounded-full border border-[#E2E8F0] text-sm font-medium\" data-dynamic=\"true\" data-kid=\"3-1-2-1\" data-name=\"current time and date widget\" data-reason=\"time and date text updated by script\">\n<i class=\"ti ti-clock text-[#94A3B8]\" data-kid=\"3-1-2-1-1\" data-name=\"clock icon\"></i>\n<span class=\"tabular-nums\" data-dynamic=\"true\" data-kid=\"3-1-2-1-2\" data-name=\"current time text\" data-reason=\"time text updated by script\">13:24:33</span>\n<span class=\"text-[#E2E8F0]\" data-kid=\"3-1-2-1-3\" data-name=\"separator pipe\">|</span>\n<span class=\"text-[#94A3B8]\" data-kid=\"3-1-2-1-4\" data-name=\"current date text\">SUN 12 JUL</span>\n</div>\n<div class=\"hidden sm:flex items-center gap-2 px-4 py-1.5 bg-[#F8FAFC] rounded-full border border-[#E2E8F0] text-sm font-medium\" data-kid=\"3-1-2-2\" data-name=\"weather status widget\">\n<i class=\"ti ti-sun text-amber-500\" data-kid=\"3-1-2-2-1\" data-name=\"sun icon\"></i>\n<span data-kid=\"3-1-2-2-2\" data-name=\"weather description text\">Sunny, 74°F</span>\n</div>\n<button class=\"w-10 h-10 bg-[#2563EB] text-white rounded-full flex items-center justify-center hover:bg-[#1D4ED8] transition-colors shadow-lg\" data-kid=\"3-1-2-3\" data-name=\"add new item button\">\n<i class=\"ti ti-plus text-xl\" data-kid=\"3-1-2-3-1\" data-name=\"plus icon\"></i>\n</button>\n<button class=\"w-10 h-10 text-[#64748B] hover:bg-[#F1F5F9] rounded-full flex items-center justify-center transition-colors\" data-kid=\"3-1-2-4\" data-name=\"notifications button\">\n<i class=\"ti ti-bell text-xl\" data-kid=\"3-1-2-4-1\" data-name=\"bell icon\"></i>\n</button>\n<div class=\"flex items-center gap-3 pl-4 border-l border-[#E2E8F0]\" data-kid=\"3-1-2-5\" data-name=\"user profile container\">\n<div class=\"text-right hidden md:block\" data-kid=\"3-1-2-5-1\" data-name=\"user info container\">\n<div class=\"text-sm font-bold text-[#0A0F1E]\" data-kid=\"3-1-2-5-1-1\" data-name=\"user name\">Piyush Sharma</div>\n<div class=\"text-[10px] font-bold text-[#2563EB] bg-[#EFF4FF] px-2 py-0.5 rounded-md uppercase tracking-wider\" data-kid=\"3-1-2-5-1-2\" data-name=\"user role badge\">Fleet Manager</div>\n</div>\n<div class=\"w-10 h-10 rounded-full bg-[#2563EB] flex items-center justify-center text-white font-bold border-2 border-white shadow-sm\" data-kid=\"3-1-2-5-2\" data-name=\"user avatar placeholder\">\n          PS\n        </div>\n</div>\n</div>\n</nav>\n<div class=\"max-w-[1600px] mx-auto px-8 pt-8 space-y-8\" data-kid=\"3-2\" data-name=\"page main body container\">\n\n<header class=\"flex items-end justify-between\" data-kid=\"3-2-1\" data-name=\"page header section\">\n<div data-kid=\"3-2-1-1\" data-name=\"page title and description container\">\n<h1 class=\"text-3xl font-extrabold text-[#0A0F1E] tracking-tight mb-1\" data-kid=\"3-2-1-1-1\" data-name=\"page headline title\">Fleet Operations Dashboard</h1>\n<p class=\"text-[#64748B] text-sm\" data-kid=\"3-2-1-1-2\" data-name=\"page description text\">Monitor fleet performance, dispatch activities, maintenance, and operational health in real time.</p>\n</div>\n<div class=\"flex items-center gap-6\" data-kid=\"3-2-1-2\" data-name=\"telemetry and actions container\">\n<div class=\"text-right\" data-kid=\"3-2-1-2-1\" data-name=\"telemetry sync status container\">\n<div class=\"text-[10px] font-bold text-[#94A3B8] uppercase tracking-widest mb-1\" data-kid=\"3-2-1-2-1-1\" data-name=\"telemetry lock label\">Telemetry Lock</div>\n<div class=\"text-xs font-mono font-medium text-[#475569] bg-[#F1F5F9] px-2 py-1 rounded\" data-kid=\"3-2-1-2-1-2\" data-name=\"last synced time text\">Last synced: 13:23:50</div>\n</div>\n<button class=\"h-11 px-5 bg-[#2563EB] text-white rounded-xl font-bold flex items-center gap-2 hover:bg-[#1D4ED8] transition-all shadow-md active:scale-95\" data-kid=\"3-2-1-2-2\" data-name=\"refresh data button\">\n<i class=\"ti ti-refresh text-lg animate-spin-slow\" data-kid=\"3-2-1-2-2-1\" data-name=\"refresh icon\"></i>\n          Refresh Data\n        </button>\n</div>\n</header>\n\n<div class=\"bg-white rounded-[18px] border border-[#E2E8F0] p-4 flex items-center gap-4 card-shadow\" data-kid=\"3-2-2\" data-name=\"filters bar container\">\n<div class=\"flex items-center gap-2 px-4 border-r border-[#E2E8F0] py-1\" data-kid=\"3-2-2-1\" data-name=\"filters label container\">\n<i class=\"ti ti-filter text-[#2563EB]\" data-kid=\"3-2-2-1-1\" data-name=\"filter icon\"></i>\n<span class=\"text-sm font-bold\" data-kid=\"3-2-2-1-2\" data-name=\"filters label text\">Filters</span>\n</div>\n<div class=\"flex-1 flex gap-4 overflow-x-auto no-scrollbar\" data-kid=\"3-2-2-2\" data-name=\"filters options list\">\n<div class=\"min-w-[160px] h-10 px-4 flex items-center justify-between border border-[#E2E8F0] rounded-full text-sm font-medium hover:border-[#2563EB] cursor-pointer transition-colors bg-[#F8FAFC]\" data-kid=\"3-2-2-2-1\" data-name=\"all types filter button\">\n<span data-kid=\"3-2-2-2-1-1\" data-name=\"all types label\">All Types</span>\n<i class=\"ti ti-chevron-down text-[#94A3B8]\" data-kid=\"3-2-2-2-1-2\" data-name=\"all types chevron icon\"></i>\n</div>\n<div class=\"min-w-[160px] h-10 px-4 flex items-center justify-between border border-[#E2E8F0] rounded-full text-sm font-medium hover:border-[#2563EB] cursor-pointer transition-colors bg-[#F8FAFC]\" data-kid=\"3-2-2-2-2\" data-name=\"all statuses filter button\">\n<span data-kid=\"3-2-2-2-2-1\" data-name=\"all statuses label\">All Statuses</span>\n<i class=\"ti ti-chevron-down text-[#94A3B8]\" data-kid=\"3-2-2-2-2-2\" data-name=\"all statuses chevron icon\"></i>\n</div>\n<div class=\"min-w-[160px] h-10 px-4 flex items-center justify-between border border-[#E2E8F0] rounded-full text-sm font-medium hover:border-[#2563EB] cursor-pointer transition-colors bg-[#F8FAFC]\" data-kid=\"3-2-2-2-3\" data-name=\"all regions filter button\">\n<span data-kid=\"3-2-2-2-3-1\" data-name=\"all regions label\">All Regions</span>\n<i class=\"ti ti-chevron-down text-[#94A3B8]\" data-kid=\"3-2-2-2-3-2\" data-name=\"all regions chevron icon\"></i>\n</div>\n<div class=\"min-w-[160px] h-10 px-4 flex items-center justify-between border border-[#E2E8F0] rounded-full text-sm font-medium hover:border-[#2563EB] cursor-pointer transition-colors bg-[#F8FAFC]\" data-kid=\"3-2-2-2-4\" data-name=\"all drivers filter button\">\n<span data-kid=\"3-2-2-2-4-1\" data-name=\"all drivers label\">All Drivers</span>\n<i class=\"ti ti-chevron-down text-[#94A3B8]\" data-kid=\"3-2-2-2-4-2\" data-name=\"all drivers chevron icon\"></i>\n</div>\n</div>\n</div>\n\n<div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6\" data-kid=\"3-2-3\" data-name=\"kpi summary grid\">\n\n<div class=\"bg-white rounded-[18px] border border-[#E2E8F0] p-6 card-shadow hover:translate-y-[-2px] transition-all\" data-kid=\"3-2-3-1\" data-name=\"active vehicles kpi card\">\n<div class=\"flex items-start justify-between mb-4\" data-kid=\"3-2-3-1-1\" data-name=\"kpi header container\">\n<div class=\"icon-tile bg-[#EFF4FF]\" data-kid=\"3-2-3-1-1-1\" data-name=\"icon tile\">\n<i class=\"ti ti-truck text-[#2563EB]\" data-kid=\"3-2-3-1-1-1-1\" data-name=\"truck icon\"></i>\n</div>\n<div class=\"flex items-center gap-1 text-[11px] font-bold text-[#059669] bg-[#ECFDF5] px-2 py-1 rounded-full\" data-kid=\"3-2-3-1-1-2\" data-name=\"kpi growth trend indicator\">\n<i class=\"ti ti-arrow-up\" data-kid=\"3-2-3-1-1-2-1\" data-name=\"arrow up icon\"></i> +8%\n          </div>\n</div>\n<div class=\"text-4xl font-extrabold text-[#0A0F1E] tabular-nums mb-1\" data-kid=\"3-2-3-1-2\" data-name=\"kpi value number\">121</div>\n<div class=\"text-[10px] font-bold text-[#94A3B8] uppercase tracking-widest mb-1\" data-kid=\"3-2-3-1-3\" data-name=\"kpi label\">Active Vehicles</div>\n<div class=\"text-xs text-[#64748B] flex justify-between items-end\" data-kid=\"3-2-3-1-4\" data-name=\"kpi description and sparkline\">\n          Currently operational\n          <div class=\"w-16 h-8 opacity-50\" data-kid=\"3-2-3-1-4-1\" data-name=\"sparkline canvas container\">\n<canvas data-dynamic=\"true\" data-kid=\"3-2-3-1-4-1-1\" data-name=\"active vehicles sparkline\" data-reason=\"chart rendered by script\" id=\"sparkline-1\"></canvas>\n</div>\n</div>\n</div>\n\n<div class=\"bg-white rounded-[18px] border border-[#E2E8F0] p-6 card-shadow hover:translate-y-[-2px] transition-all\" data-kid=\"3-2-3-2\" data-name=\"available vehicles kpi card\">\n<div class=\"flex items-start justify-between mb-4\" data-kid=\"3-2-3-2-1\" data-name=\"kpi header container\">\n<div class=\"icon-tile bg-[#ECFDF5]\" data-kid=\"3-2-3-2-1-1\" data-name=\"icon tile\">\n<i class=\"ti ti-circle-check text-[#059669]\" data-kid=\"3-2-3-2-1-1-1\" data-name=\"check icon\"></i>\n</div>\n<div class=\"flex items-center gap-1 text-[11px] font-bold text-[#059669] bg-[#ECFDF5] px-2 py-1 rounded-full\" data-kid=\"3-2-3-2-1-2\" data-name=\"kpi growth trend indicator\">\n<i class=\"ti ti-arrow-up\" data-kid=\"3-2-3-2-1-2-1\" data-name=\"arrow up icon\"></i> +3%\n          </div>\n</div>\n<div class=\"text-4xl font-extrabold text-[#0A0F1E] tabular-nums mb-1\" data-kid=\"3-2-3-2-2\" data-name=\"kpi value number\">78</div>\n<div class=\"text-[10px] font-bold text-[#94A3B8] uppercase tracking-widest mb-1\" data-kid=\"3-2-3-2-3\" data-name=\"kpi label\">Available Vehicles</div>\n<div class=\"text-xs text-[#64748B] flex justify-between items-end\" data-kid=\"3-2-3-2-4\" data-name=\"kpi description and sparkline\">\n          Ready for dispatch\n          <div class=\"w-16 h-8 opacity-50\" data-kid=\"3-2-3-2-4-1\" data-name=\"sparkline canvas container\">\n<canvas data-dynamic=\"true\" data-kid=\"3-2-3-2-4-1-1\" data-name=\"available vehicles sparkline\" data-reason=\"chart rendered by script\" id=\"sparkline-2\"></canvas>\n</div>\n</div>\n</div>\n\n<div class=\"bg-white rounded-[18px] border border-[#E2E8F0] p-6 card-shadow hover:translate-y-[-2px] transition-all\" data-kid=\"3-2-3-3\" data-name=\"maintenance kpi card\">\n<div class=\"flex items-start justify-between mb-4\" data-kid=\"3-2-3-3-1\" data-name=\"kpi header container\">\n<div class=\"icon-tile bg-[#FEF2F2]\" data-kid=\"3-2-3-3-1-1\" data-name=\"icon tile\">\n<i class=\"ti ti-wrench text-[#DC2626]\" data-kid=\"3-2-3-3-1-1-1\" data-name=\"wrench icon\"></i>\n</div>\n<div class=\"flex items-center gap-1 text-[11px] font-bold text-[#DC2626] bg-[#FEF2F2] px-2 py-1 rounded-full\" data-ki